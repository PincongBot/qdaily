ormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */ table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:12.0pt; \tfont-family:Cambria; \tmso-ascii-font-family:Cambria; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Cambria; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->    </p>\n<p><a href=\"http://patinn.com\">Pat Inn</a> 位于全年温暖的Chichijima岛上，是由一个家族经营的。2015 年，该家族邀请建筑事务所 <a href=\"http://www.kichi-d.com\">Kichi Architectural Design</a> 对酒店进行了设计，建成后的酒店十分现代，共有 13 间客房，包括传统双人房和日式榻榻米房间。此外，酒店还有一个图书馆和一家地方风味餐厅。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021301213SpCx5rgBlQhZiGo.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66627358\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702130122CxE10Yw2ozWF49lc.jpg\" alt=\"\" class=\"\" data-ratio=\"0.67021277\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702130122FQp9tlrINTc15bjm.jpg\" alt=\"\" class=\"\" data-ratio=\"1.5007776\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702130123kr0AKpoZbn6JgI9v.jpg\" alt=\"\" class=\"\" data-ratio=\"1.41581259\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702130123G6IVocAvnEYX0m13.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702130124VMS8pxeyva0nDTtJ.jpg\" alt=\"\" class=\"\" data-ratio=\"1.49568966\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">至于小笠原群岛，它是远古时代海底火山喷发形成的岛屿，少平地，多海岸悬崖。它属于亚热带海洋性气候，气温变化较小，一年当中都难以见到霜雪，岛上灌木枞生，植物丰富，还有一些特有的生物，如眼部羽毛呈黑色三角形的黑眼夜莺、展开翅膀可达 2 米宽的狐蝠、在暗处会发出绿色萤光的绿水母等，是个很不错的旅行目的地。</p>\n<p class=\"\">如果你对这片小岛感兴趣，可以先阅读杰克·伦敦的小说《小笠原群岛》。<br></p>\n<p>题图来源：<a href=\"http://www.spoon-tamago.com/2016/02/04/pat-inn-a-modernist-hotel-on-tokyos-tropical-chichijima/\">spoon-tamago</a></p>\n\n"}