rity=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>乐高积木不仅仅是孩子喜爱的玩具，也是许多艺术家的心头爱。来自波兰的摄影师 Michal Kulesza 就让乐高积木走入了自己的生活。他为乐高拍摄了一组“生活照”，从黄油面包到寿司，从薯条到巧克力，从香槟到碎胡渣，你会发现原来乐高积木还可以这么玩儿。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141629ftpOxbwCnoeYUM0G.jpg\" alt=\"\" data-ratio=\"0.45648148\" data-format=\"jpeg\">\r\n</figure></div>\n<p>Kulesza 从小就是个乐高迷，他从乐高积木里能看到无数的可能性，“我觉得，其实乐高积木可以搭建任何一个东西，它有无数的可能。甚至在鸡毛蒜皮的日常生活中，你也可以看到乐高的影子。拍摄这些创意照片，是希望大家能够在看到的时候觉得很惊喜，因为有一些不常见的点子在里面。” Kulesza 介绍说。</p>\n<p>来看一看这一组名为“ Lego Everyday Objects ”的摄影作品。如果你有兴趣，可以访问 <a href=\"https://tookapic.com/michalkulesza\" target=\"_blank\">TookAPic.com</a> 看到更多 Kulesza 的乐高图集。</p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141629sFIKLT9CEJhbpnoj.jpg\" alt=\"\" class=\"\" data-ratio=\"0.74935065\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021416300xnPTSdYR5o9jzDK.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141630Nviw1EbKsPJDZeUR.jpg\" alt=\"\" data-ratio=\"0.75064935\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141631SLAywRnjbEcoZpsH.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141631n3UK1hGieqmMkB8j.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021416327vM0CkyKuple1ajc.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141632fMHxBvjidE2alcD5.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141632vsKtFgfhUIr5G0da.jpg\" alt=\"\" data-ratio=\"0.56210526\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141633jdkSKI5XneBUi7g9.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141633TjFLQsRckzJZdpq3.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021416346sOLtipug5WHx9M2.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\"></p>\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141634oOhAbLxd0t31Q8Zz.jpg\" alt=\"\" data-ratio=\"0.66623377\" data-format=\"jpeg\"><br></figure><p></p>\n<figure style=\"margin:0;\">之前另一位艺术家 Jeff Friesen 也用乐高打造过自己的摄影项目“ 50 States of Lego ”—— Jeff 用乐高玩具模拟出 50 个美国城市的样子。 Jeff 综合了当地的风景、民情、传统、风情，用乐高拼建出一些很有代表性的场景，来代表一个美国的城市。</figure><p></p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141635k4xe86LlZpISHwJT.jpg\" alt=\"\" class=\"\" data-ratio=\"0.8\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">弗罗里达</div></figcaption></figure></div>\n<p class=\"\">\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021416352NcoudBRaXbFyj7L.jpg\" alt=\"\" class=\"\" data-ratio=\"0.8\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">新墨西哥</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141635yJDK5Bx2HgNuitCP.jpg\" alt=\"\" class=\"\" data-ratio=\"0.8\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">纽约</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141636rsyEYuWKv7MHDZRP.jpg\" alt=\"\" class=\"\" data-ratio=\"0.8\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">夏威夷</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141637Ruqpfy0461SN8wMv.jpg\" alt=\"\" class=\"\" data-ratio=\"0.8\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">乔治亚洲</div></figcaption></figure></div>\n<p>因为乐高被认为更能激发创造性，所以相较于其他玩具公司，乐高的受众群体更为广泛。2014 年下半年，乐高取代芭比娃娃的母公司美泰，成为全球最大的玩具公司。我们之前也报道过许多关于乐高的创意拼搭，你可以在文后的延伸阅读部分看到。</p>\n<p class=\"\">题图来自 \r\n\r\nMichal Kulesza \r\n\r\n</p>\n\n"}