tion Locked=\"false\" Priority=\"65\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>“我很少做工业设计，只有当我觉得这件产品通过工业化生产能产生附加值时才会这么做。与其设计无聊、非个人化的产品，我真的愿意什么也不做。”</p>\n<p><a href=\"http://www.coolhunting.com/design/maarten-baas\">这话出自荷兰知名设计师 Maarten Baas</a>。他被不少人认为是本世纪荷兰最有影响力的设计师之一，作品充满概念性，看起来介于艺术和设计之间，总是戏剧化、大胆夸张，有时候也很好玩。</p>\n<p>Maarten Baas 最近推出了自己的新作品，家具系列“壳（Carapace）”。这系列家具总共 6 件，同样打破常规、造型独特，系列名称“壳”指的就是甲壳虫或乌龟的保护壳。这个系列于今年 3 月 2 日至 4 月 30 日在纽约的<a href=\"http://carpentersworkshopgallery.com/\">木匠作坊艺术馆</a>（Carpenters Workshop Gallery）展出。</p>\n<p>“壳”系列包括扶手椅、桌子、不同尺寸规格的橱柜，每一件家具都边角圆润，看起来胖乎乎的；家具表面用镀铜板拼接而成，这些小的镀金属版经过手工弯曲、点焊之后才形成了如同保护壳的外形。</p>\n<div class=\"com-insert-images\">\n<figure class=\"\">\r\n    <img src=\"img/uploads/20160702133322pTYUBDFASf89qJGa.jpg\" alt=\"\" class=\"\" data-ratio=\"0.5\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">柜子</div></figcaption></figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133323io4Ccmds5SgPxhUw.jpg\" alt=\"\" class=\"\" data-ratio=\"0.5\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">圆球一样的扶手椅</div></figcaption></figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133323SvN4XAYpCj8kFTM3.jpg\" alt=\"\" class=\"\" data-ratio=\"1.74327628\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">不同款式的橱柜</div></figcaption></figure></div>\n<p><a href=\"http://carpentersworkshopgallery.com/en/Exhibitions/Maarten-Baas--Carapace--New-York\">据木匠作坊艺术馆官网上的介绍</a>，这个系列最初缘起于设计师对 1950 年代电冰箱的兴趣，后来他又研究了自然中那些天然的、弯曲的“壳”，渐渐有了现在的想法。其核心设计理念是“坚硬的外壳保护柔软的身体”“金属外壳之内其实藏着精致的宝贝”。</p>\n<p>“在坚硬的表层下，仍有一些美好而丰盛的东西在茂盛生长着。这组作品探索了脆弱感与生长的欲望之间的冲突。”<a href=\"http://carpentersworkshopgallery.com/en/Exhibitions/Maarten-Baas--Carapace--New-York\">Maarten Baas 说</a>。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133324nR5agd2KVeuM40SF.jpg\" alt=\"\" data-ratio=\"0.333\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133325W5j8M0Ep6VTA4BSy.jpg\" alt=\"\" class=\"\" data-ratio=\"0.466\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">细节</div></figcaption></figure></div>\n<p>这里还有 Maarten Baas 过去的作品，或许你也会对这些奇特、怪异而充满想象力的家具感兴趣。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133325WG6qn4Acm5OMFHrv.jpg\" alt=\"\" class=\"\" data-ratio=\"2.78548387\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">  2004 年开始推出的，令 Maarten Baas 名声大噪的 烟熏（Smoke） 系列  </div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133326IHnDV2juLi90h13t.jpg\" alt=\"\" class=\"\" data-ratio=\"1.35\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">粘土（Clay）系列</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133330c6Q3L4xN8Sew2hfs.jpg\" alt=\"\" class=\"\" data-ratio=\"0.63375\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">  \"Hey, chair, be a bookshelf!\"系列，把二手商店里的家具重新堆叠、组合、涂层，变成一个架子   </div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702133331q6IODg4kVudtXE1H.jpg\" alt=\"\" class=\"\" data-ratio=\"2.13930348\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">2014 年他在米兰家具展中的个人展览</div></figcaption></figure></div>\n<p>          <!--[if gte mso 9]><xml>  <w:WordDocument>   <w:View>Normal</w:View>   <w:Zoom>0</w:Zoom>   <w:TrackMoves></w:TrackMoves>   <w:TrackFormatting></w:TrackFormatting>   <w:PunctuationKerning></w:PunctuationKerning>   <w:DrawingGridVerticalSpacing>7.8 磅</w:DrawingGridVerticalSpacing>   <w:DisplayHorizontalDrawingGridEvery>0</w:DisplayHorizontalDrawingGridEvery>   <w:DisplayVerticalDrawingGridEvery>2</w:DisplayVerticalDrawingGridEvery>   <w:ValidateAgainstSchemas></w:ValidateAgainstSchemas>   <w:SaveIfXMLInvalid>false</w:SaveIfXMLInvalid>   <w:IgnoreMixedContent>false</w:IgnoreMixedContent>   <w:AlwaysShowPlaceholderText>false</w:AlwaysShowPlaceholderText>   <w:DoNotPromoteQF></w:DoNotPromoteQF>   <w:LidThemeOther>EN-US</w:LidThemeOther>   <w:LidThemeAsian>ZH-CN</w:LidThemeAsian>   <w:LidThemeComplexScript>X-NONE</w:LidThemeComplexScript>   <w:Compatibility>    <w:SpaceForUL></w:SpaceForUL>    <w:BalanceSingleByteDoubleByteWidth></w:BalanceSingleByteDoubleByteWidth>    <w:DoNotLeaveBackslashAlone></w:DoNotLeaveBackslashAlone>    <w:ULTrailSpace></w:ULTrailSpace>    <w:DoNotExpandShiftReturn></w:DoNotExpandShiftReturn>    <w:AdjustLineHeightInTable></w:AdjustLineHeightInTable>    <w:BreakWrappe