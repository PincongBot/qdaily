d=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>最近，伦敦设计工作室 Studio h 为 Svalbarði 品牌的冰川水设计了一款包装。软木塞、全透明玻璃瓶、精巧的雪花 logo 和让人联想到冰川的蓝绿色质感为主的色调。</p>\n<p>这款高级水的水源来自于挪威斯瓦尔巴特群岛逐渐崩解的冰川，在它们彻底消融之前充分利用。这些原始冰川已经有着几千年的历史，并且还和最初形成时一样纯净。和我们最常接触到的矿泉水不同，它几乎不含任何矿物质。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702142520Tyfhwpz1naUmge5b.jpg\" alt=\"\" data-ratio=\"0.6203125\" data-format=\"jpeg\">\r\n</figure></div>\n<p>创始人 Jamal Qureshi 在 Svalbarði 旅游时给妻子装了一瓶融化的冰川水回家煮茶，却从中窥见了商机。它的瓶装水单价就达到 300 克朗（约 230 元人民币）。考虑到要去岛上将采集自然崩解的冰块并运输回国的成本，这样的价格也不算太不合理。但普通消费者的反应大概会和 Jamal 的很多朋友一样，“‘你是疯了吧？’他们这样问我。”</p>\n<p>但 Jamal 的自信是建立在大量市场调研的基础上的，他将瓶装水市场分为三大类：第一类是最为普遍的，也就是我们常说的优质矿泉水。第二类是纪念品市场，好比你将当地自然纯净的水源带回家作为到过那里的纪念。这类瓶装水通常会用精美的包装来吸引你的眼球。第三类就是奢侈品市场了。</p>\n<div class=\"com-insert-images medium-insert-images-wide\">\n<figure class=\"\">\r\n    <img src=\"img/uploads/20160702142520nV0T327tClhwEIv9.jpg\" alt=\"\" class=\"\" data-ratio=\"1.19074074\" data-format=\"jpeg\">\r\n</figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702142521OD8fxXhwzn5Ke1L6.jpg\" alt=\"\" class=\"\" data-ratio=\"0.26944444\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702142521K8x3nhvqFed5cbIm.jpg\" alt=\"\" class=\"\" data-ratio=\"1.18703704\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702142522hwLPApG2RtIoOaYn.jpg\" alt=\"\" data-ratio=\"0.66481481\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<p class=\"\">“Svalbarði 的定位应该是第二类，它会成为非常棒的一份礼品。”<a href=\"http://svalbardposten.no/index.php?page=vis_nyhet&amp;NyhetID=6462\" style=\"background-color: rgb(255, 255, 255);\">Jamal 这样说。</a></p>\n<p>        <!--[if gte mso 9]><xml>     <o:AllowPNG></o:AllowPNG>   </xml><![endif]-->   <!--[if gte mso 9]><xml>  <w:WordDocument>   <w:View>Normal</w:View>   <w:Zoom>0</w:Zoom>   <w:TrackMoves></w:TrackMoves>   <w:TrackFormatting></w:TrackFormatting>   <w:PunctuationKerning></w:PunctuationKerning>   <w:DrawingGridVerticalSpacing>7.8 磅</w:DrawingGridVerticalSpacing>   <w:DisplayHorizontalDrawingGridEvery>0</w:DisplayHorizontalDrawingGridEvery>   <w:DisplayVerticalDrawingGridEvery>2</w:DisplayVerticalDrawingGridEvery>   <w:ValidateAgainstSchemas></w:ValidateAgainstSchemas>   <w:SaveIfXMLInvalid>false</w:SaveIfXMLInvalid>   <w:IgnoreMixedContent>false</w:IgnoreMixedContent>   <w:AlwaysShowPlaceholderText>false</w:AlwaysShowPlaceholderText>   <w:DoNotPromoteQF></w:DoNotPromoteQF>   <w:LidThemeOther>EN-US</w:LidThemeOther>   <w:LidThemeAsian>ZH-CN</w:LidThemeAsian>   <w:LidThemeComplexScript>X-NONE</w:LidThemeComplexScript>   <w:Compatibility>    <w:SpaceForUL></w:SpaceForUL>    <w:BalanceSingleByteDoubleByteWidth></w:BalanceSingleByteDoubleByteWidth>    <w:DoNotLeaveBackslashAlone></w:DoNotLeaveBackslashAlone>    <w:ULTrailSpace></w:ULTrailSpace>    <w:DoNotExpandShiftReturn></w:DoNotExpandShiftReturn>    <w:AdjustLineHeightInTable></w:AdjustLineHeightInTable>    <w:BreakWrappedTables></w:BreakWrappedTables>    <w:SnapToGridInCell></w:SnapToGridInCell>    <w:WrapTextWithPunct></w:WrapTextWithPunct>    <w:UseAsianBreakRules></w:UseAsianBre