hideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>Svalbarði 最初一批只生产了 13000 瓶水在当地出售，但是在去年一场高端水品牌的交流会上，Svalbarði 引起了一家韩国公司的注意，他们签署了一份协议，买下了 Svalbarði 的 10 万瓶瓶装水，打算投放到韩国的酒店市场。</p>\n<p class=\"\">事实上，这些普通消费者可能无法理解的“高级水”已经有着一个非常成熟的市场。如果你常逛 ins，就可以很明显地发现姑娘们不仅爱晒包包、爱晒口红、爱晒鞋子、爱晒星巴克，还爱晒高级瓶装水的包装。</p>\n<div class=\"com-insert-images medium-insert-images-wide\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702142522ifTVgIqLwmoHQZuF.jpg\" alt=\"\" class=\"\" data-ratio=\"1.77866667\" data-format=\"jpeg\">\r\n<figcaption class=\"\">#Fillico</figcaption></figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702142523lI0f8qXZDOWQwBiK.jpg\" alt=\"\" class=\"\" data-ratio=\"1.77866667\" data-format=\"jpeg\">\r\n<figcaption class=\"\">#blkwater</figcaption></figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702142524hgewT1zmPLOStlV6.jpg\" alt=\"\" class=\"\" data-ratio=\"1.77866667\" data-format=\"jpeg\">\r\n<figcaption class=\"\">#VOSS</figcaption></figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702142525LUo9XSQiZut4FYAq.jpg\" alt=\"\" class=\"\" data-ratio=\"1.77866667\" data-format=\"jpeg\">\r\n<figcaption class=\"\">#FIJI water</figcaption></figure>\n</div>\n<p class=\"\">或许正如 Jamal 所说：“在这个（高端）市场里，注重的是产品背后的故事，以及产品的包装和外形。”</p>\n<p class=\"\">图片来源：instagram、Studio h</p>\n<div class=\"com-insert-images\"><figure class=\"placeholder\"></figure></div>\n\n"}