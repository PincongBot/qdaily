x;\"> <img src=\"img/uploads/20180702114950ekmFAI5SsxdZ0vEW.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807021150033TnkF0gNwYyldQCH.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807021150228nIWqYN4wOfbA96j.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702115041ZwTgFebnxs10mGB5.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702115118sBpInP9Vv6EcgqN8.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702115132o8E4m1Zc5j0gYu7x.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702115143iuImtqCDdh4ToZP1.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702115155o2V5WbYehAlX8jrw.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702115208BDdLOMPf5QExiUsk.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure></div><p><strong>Sonia Rykiel 2018 秋冬高定系列</strong>。这是创意总监 Julie de Libran 2014 年加入该品牌以来的首个高定系列。</p><p>被《女装日报》冠以“针织女王”称呼的 Sonia Rykiel 两年前去世，Julie de Libran 因此把新系列主题设置为 “L’Atelier Sonia Rykiel”，希望重新展现创始人的经典设计：厚呢短大衣、罗纹毛衣、运动裤、条纹运动衫、裙裤等。</p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807021237145kq0f2aQt4OHmAlF.jpg\" data-ratio=\"1.499268\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702123730FHW8NAwKYv9ujLQz.jpg\" data-ratio=\"1.499268\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180702123737p6WPEyoV8BrO1KmY.jpg\" data-ratio=\"1.499268\" data-format=\"