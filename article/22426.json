"false\" Priority=\"65\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>瑞士的 Whitepod 酒店不能算是一个容易抵达的地方。它位于 Dents-du-Midi 山脉、阿尔卑斯山脉在瑞士发祥的地方。要去到那里，需要先驱车去一个海拔 1250 米高的小山村，再步行二十分钟攀爬到 1400 米高处的客房去。</p>\n<p>听起来要住进去很费劲，交通也不方便，但这个酒店就是很受欢迎。在 Google 上搜索店名 Whitepod Eco-luxury Hotel and Alpine Experience 能搜到<a href=\"https://www.google.com/search?q=whitepod+eco-luxury+hotel&amp;newwindow=1&amp;client=aff-cs-360chromium&amp;hs=ksF&amp;biw=1366&amp;bih=640&amp;ei=H-zDVqm0Fs_IjwOlrorQBQ&amp;start=0&amp;sa=N\"> 1.48 万</a>条结果，<a href=\"http://www.myswitzerland.com/zo/hotels/lesgiettes/whitepod-resort-15990.html\">瑞士旅游局还在官网上推荐它</a>。其中原因？大概因为 Whitepod 的确是一家特别的酒店，能让你像去野营一样完全被迷人的自然环绕，但又能使用完整的现代设施和服务。</p>\n<p>从村庄里的接待处办理入住手续之后，顾客将领到一个背包，一张地图，一个帽灯，一双雪地鞋以及手杖，在这些装备辅助下步行前往住处。如果在冬天，则有专人用机械雪橇运送顾客的行李。在白皑皑的雪山上，当看到十数个同样被雪覆盖的圆屋子，你就知道来到客房了。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105616N5DfW9Xd8shv1mcM.jpg\" alt=\"\" data-ratio=\"0.53055556\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105616GPgvJADNjMVx69hZ.jpg\" alt=\"\" data-ratio=\"0.66375\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105616Ra2t6ucmVoJkiKIx.jpg\" alt=\"\" data-ratio=\"0.55\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">这 15 间蚕茧般的圆屋子就是 Whitepod 酒店的客房，仿佛天然的雪堆，到晚上，又像雪地里一盏盏灯。每一间房都是独立的，通过一个平坦的木质平台搭建在山上。木平台也是一个便于观景的小阳台，望出去视野很好。<br></p>\n<p>室内装潢和家具反映瑞士亲近自然的美学风格，配色都是奶白、灰色、木色等中性温柔的颜色，所选的家具也都是简洁风格的瑞士本土产品。室内由一个烧木材的火炉供暖，如果到夜晚温度降低，那就是说你该往里加木材了。火炉连着烟囱往外排气，它既是功能性设备，又为客房增加几许温馨。住进这样的客房，坐在圆顶之下，有种住在帐篷里的感觉。</p>\n<p>不过，设施就远比简陋的帐篷要完备，有大双人床，电视，落地灯，wifi 等设施，卫浴设备也齐全，浴室配备了电热器加热的热水。拉开窗帘是多面棱镜般的大窗口，让阳光充分洒入，人躺在床上就可以透过大窗看到漂亮的阿尔卑斯山风景和村庄景色。</p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105617KxJe0PRiFnATMzC5.jpg\" alt=\"\" data-ratio=\"0.74875\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105617UFK3hyvI40EcVxed.jpg\" alt=\"\" data-ratio=\"0.66625\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105618Bo1imKrZa2u6v59O.jpg\" alt=\"\" data-ratio=\"0.66625\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105618XhnCxsOGSLkt280P.jpg\" alt=\"\" data-ratio=\"0.4175705\" data-format=\"jpeg\">\r\n</figure></div>\n<p>这些客房旁边还有个大木屋，作为公共空间和主要的功能区，里面是酒吧，餐厅，还有会议室和桑拿房，室内的休闲娱乐活动就在木屋中进行。不过，既然来到这里，可能还是户外和自然更吸引你。Whitepod 酒店在山上有自己的私家滑雪场，斜坡长 7 公里左右。顾客可以自己登山，滑雪，骑着雪地摩托车奔驰，或者坐上狗拉的雪橇四处走走。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105619YAZ1mRNQuwxL58ay.jpg\" alt=\"\" data-ratio=\"0.61875\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105619iSHnUx13fyK8NAOY.jpg\" alt=\"\" data-ratio=\"0.665\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105619irycoUhR40qMWAeS.jpg\" alt=\"\" data-ratio=\"0.6675\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702105620afk76lmjDbYWJI0Z.jpg\" alt=\"\" data-ratio=\"0.66625\" data-format=\"jpeg\">\r\n</figure></div>\n<p>这里在夏天也开放，会有另一番风景。不过对于喜欢雪的人来说，冬天出游会是个更好的选择。</p>\n<p class=\"\">\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n</p>\n<p>酒店地址：Les Cerniers，1871 Les Giettes，Switzerland<br> <!--[endif]--></p>\n<p>          <!--[if gte mso 9]><xml>  <w:WordDocument>   <w:View>Normal</w:View>   <w:Zoom>0</w:Zoom>   <w:TrackMoves></w:TrackMoves>   <w:TrackFormatting></w:TrackFormatting>   <w:PunctuationKerning></w:PunctuationKerning>   <w:DrawingGridVerticalSpacing>7.8 磅</w:DrawingGridVerticalSpacing>   <w:DisplayHorizontalDrawingGridEvery>0</w:DisplayHorizontalDrawingGridEvery>   <w:DisplayVerticalDrawingGridEvery>2</w:DisplayVerticalDrawingGridEvery>   <w:ValidateAgainstSchemas></w:ValidateAgainstSchemas>   <w:SaveIfXMLInvalid>false</w:SaveIfXMLInvalid>   <w:IgnoreMixedContent>false</w:IgnoreMixedContent>   <w:AlwaysShowPlaceholderText>false</w:AlwaysShowPlaceholderText>   <w:DoNotPromoteQF></w:DoNotPromoteQF>   <w:LidThemeOther>EN-US</w:LidThemeOther>   <w:LidThemeAsian>ZH-CN</w:LidThemeAsian>   <w:LidThemeComplexScript>X-NONE</w:LidThemeComplexScript>   <w:Compatibility>    <w:SpaceForUL></w:SpaceForUL>    <w:BalanceSingleByteDoubleByteWidth></w:BalanceSingleByteDoubleByteWidth>    <w:DoNotLeaveBackslashAlone></w:DoNotLeaveBackslashAlone>    <w:ULTrailSpace></w:ULTrailSpace>    <w:DoNotExpandShiftReturn></w:DoN