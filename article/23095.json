e\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>麦当劳也开始用 VR 做噱头了——用麦当劳的餐盒改造而成的虚拟现实眼镜。最近，麦当劳在瑞典推出了一款全新的开心乐园餐，餐盒可以在用餐结束后被改造成与谷歌 Cardboard 类似的虚拟现实眼镜，不过，可能有股炸鸡味儿哦。</p>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"http://v.qq.com/iframe/player.html?vid=m0186mygw47&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t</figure>\r\n\t\r\n</div>\n<p>目前这个 VR 眼镜还只是麦当劳的一次试水，只在瑞典的 14 家麦当劳餐厅里限量发售，一共只有 3,500 套，虽然它的售价只有 4 美元，但想体验一下这个带有炸鸡味儿的虚拟现实眼镜，看来还得靠抢。不过麦当劳也表示，如果 VR 眼镜在瑞典的反响不错，就有可能在全球范围内推广。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125234ubSJ2rACgNXodDnt.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure></div>\n<p>这其实是麦当劳为瑞典体育节（Sportlov）打造的一系列营销活动，在这期间瑞典的学校会放一周假，孩子们和家长们有机会去体验滑雪等冬季运动。配合 VR 眼镜推出的，还有一款以滑雪为主题的虚拟现实小游戏——“坡道明星”（Slope Stars），戴上虚拟现实设备，就可以身临其境地感受滑雪了。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021252340gkALdTRZaH375hm.jpg\" alt=\"\" class=\"\" data-ratio=\"0.7484375\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">必胜客的“电影放映机”</div></figcaption></figure></div>\n<p class=\"\">\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n</p>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe src=\"http://player.youku.com/embed/XMTI1OTkzMTQyMA==\" frameborder=\"0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t<figcaption class=\"\"><div style=\"text-align: center;\">必胜客披萨盒的介绍视频</div></figcaption></figure>\r\n\t\r\n</div>\n<p>总之，这款眼镜听起来还不错，尽管戴上去之后可能油乎乎的，但是孩子们估计也不会管那么多。之前在吃完的餐盒身上动脑筋的，还有必胜客。去年六月，必胜客曾在香港推出新型披萨外卖餐盒，把外卖餐盒直接改装成了“电影放映机”。扫一扫餐盒上的二维码就能从 Netflix 上下载免费的影片观看。这不失为一个招揽顾客的好方法，当时还真有人为了这个电影放映机去叫外卖披萨。</p>\n<p class=\"\">题图来自 Adweek.com </p>\n\n"}