=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */ table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:12.0pt; \tfont-family:Cambria; \tmso-ascii-font-family:Cambria; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Cambria; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->    </p>\n<p>这是一本 256 页厚的精装英文书，探讨的是时尚和疯狂之间的关系。书里展示了许多前卫的服装作品，它们或突出、或变形，改变着人身体的轮廓。这些作品大多直白、前卫和颠覆。</p>\n<p>随着新技术和新材料的使用，过去我们不敢想象的服装在今天成为了可能——高科技面料和熔融形式不再是科幻，而是现实。三位编辑选取了一些经典的服装作品，重新定义了“服装”，时尚在不断地塑造着它本身。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/2016070312200052ogDAsRNZfVUp0J.jpg\" alt=\"\" class=\"\" data-ratio=\"1.35501355\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">Otherworldly 内页插图</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122001VPsYWtuI0mHieNTd.jpg\" alt=\"\" class=\"\" data-ratio=\"0.67385445\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122002JIfZDUHzOenN79CP.jpg\" alt=\"\" class=\"\" data-ratio=\"0.69637883\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122002jLaBrkHdZ94bvUtT.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122002Zwrlaf3DJNXb1p6d.jpg\" alt=\"\" class=\"\" data-ratio=\"0.67385445\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">各式奇特的服饰</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122003GC0bIW2JmaihHjF3.jpg\" alt=\"\" data-ratio=\"0.67385445\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122003kw37SZqXJ4Aanu05.jpg\" alt=\"\" data-ratio=\"0.67385445\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122004C2oj3uHvS5a9yWP0.jpg\" alt=\"\" data-ratio=\"0.67385445\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122004qoj8CIGcAgOrBJ9L.jpg\" alt=\"\" data-ratio=\"0.67385445\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images medium-insert-active\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122005B3tYeod56CykULz0.jpg\" alt=\"\" class=\"\" data-ratio=\"1.35135135\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">服饰改变着人的骨骼轮廓</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122005D6Lzp0P8i3N2sXqB.jpg\" alt=\"\" data-ratio=\"0.69637883\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160703122006