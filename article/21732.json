false\" Priority=\"65\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>越来越多大城市的人开始关注“微型公寓”的住房模式和居住理念了，尤其是像纽约、香港、东京这样的地方。<a href=\"http://www.qdaily.com/articles/19147.html\">我们此前曾报道过，2012 年纽约首次提出尝试这种模式，允许一间公寓的面积小于 37 平方米。</a></p>\n<p>现在，想要住在廉价小公寓的纽约人又有了新的选择：他们可以住进纽约最古老的购物中心里去。这座叫 The Arcade （中译“拱廊”）的购物中心建于 1828 年，是美国第一家封闭的室内购物中心。经过美国建筑事务所 Northeast Collaborative Architects （NCA）的改造，The Arcade 同时容纳公寓和零售空间，一楼是小型商铺，二三楼则有 48 间配置齐全的微型公寓。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702172202OIXb8hjrsB23kG1m.jpg\" alt=\"\" data-ratio=\"0.75100942\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure class=\"\">\r\n    <img src=\"img/uploads/20160702172203VL1Q4ogJBmMFXEC7.jpg\" alt=\"\" class=\"\" data-ratio=\"0.59803922\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">改造后的 The Arcade</div></figcaption></figure></div>\n<p>The Arcade 是一座希腊复兴式建筑。18 世纪晚期到 19 世纪初，美国曾有一次建筑风格变革的风潮，建筑师纷纷模仿古希腊建筑特点进行设计。这个购物中心的入口处就有高大的立柱，内部是花岗岩墙壁，还有一个宽阔有天井的大中庭，你可以从中看到复古风格。</p>\n<p>但由于受到线上购物的冲击和 2008 年经济危机的影响，The Arcade 在美国经济很差的 2008 年停止营业，还被列为\"纽约十大最濒危资产”。通常，像这样体量、用于休闲娱乐的建筑关门之后往往会被改建成功能性建筑，如医疗中心或教堂。但一位热衷于微型公寓概念的开发商 Evan Granoff 将 The Arcade 买下，委托 NCA 把它改造成了微型公寓。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702172203d6KsrbtaYJPwGhRB.jpg\" alt=\"\" data-ratio=\"0.65960912\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702172204RmOVL6wFJcns3glW.jpg\" alt=\"\" class=\"\" data-ratio=\"0.80735552\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">The Arcade 过去的样子</div></figcaption></figure></div>\n<p>整个改造进程花了 700 万美元。NCA 在保留其历史底蕴的同时让它更多功能、更现代，比如为大楼装上了面积更大的双悬窗，引入更多自然光。<a href=\"http://ncarchitects.com/portfolio/item/the-providence-arcade-%E2%80%A2-providence-rhode-island/#!\">据他们的官网介绍</a>，建筑的一层有 17 个面积不大的小店，过去生意不佳的上两层被改造成 48 间微型公寓，面积在 225 – 450 平方英尺（约合 20 – 40 平米）之间。公寓大多是一人间，也有能容纳双床和三床的房间。</p>\n<p>每间公寓内配备有床、沙发座椅、储存空间，和功能齐全的厨房。居住者共享的公共设施包括游戏室、地下储存单元、洗衣房、停车位等等。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702172204AzshRe3mQXoKGM76.jpg\" alt=\"\" data-ratio=\"0.83658171\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702172205oT3ybQJ2EX4BCV0K.jpg\" alt=\"\" data-ratio=\"0.59803922\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images medium-insert-active\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702172205oqZsY3CkwFdvtU5c.jpg\" alt=\"\" data-ratio=\"0.59803922\" data-format=\"jpeg\">\r\n</figure></div>\n<p>老建筑有各种改建和开发的潜力，把它改成微型公寓和零售空间相结合的形式，又是一种新的可能性。</p>\n<p>图片来源：<a href=\"http://ncarchitects.com/portfolio/item/the-providence-arcade-%E2%80%A2-providence-rhode-island/#!\">Northeast Collaborative Architects</a></p>\n\n"}