data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20161114085830lUy9tn47mVZshXTK.jpg\" alt=\"\" data-ratio=\"1.452020\" data-format=\"jpeg\">\r\n</figure></div><p class=\"\">&nbsp;</p>"}