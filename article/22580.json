henUsed=\"false\" Name=\"Medium List 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>日本设计师偏爱木材早已不是新鲜事，木材被广泛用于建筑和室内和各式产品设计中。尽管知道这一点，看到这个设计你可能还是会感到眼前一亮。</p>\n<p>日本建筑师<a href=\"http://jun-igarashi.com/en/top.html\">五十岚淳（Jun Igarashi）</a>联合日本山口艺术媒体中心的研究团队 <a href=\"http://interlab.ycam.jp/en/\">YCAM InterLab</a> 设计了一个木结构的游乐场。游乐场位于北海道札幌市的大通公园内，设计理念源于葱郁的树林。使用了木头的材质，让它看起来跟水泥或其他五颜六色材料设计建造的游乐场相比有截然不同的气质。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171645IBL7oPfAz2rHSmnw.jpg\" alt=\"\" data-ratio=\"0.66625917\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171645ztvWY8P4d5bXKoq6.jpg\" alt=\"\" data-ratio=\"0.66625917\" data-format=\"jpeg\">\r\n</figure></div>\n<p>这里所选用的木头皆为本地材料，设计师对材料进行了不同的处理。游乐场看起来是波动起伏的缎带交织在一起，表面使用平滑的木板，而作为支撑的木架则保持原始粗糙，这种对比带来特殊的美感。整个游乐场是一系列走道、“高地”、斜坡，孩子们可以在上面自在地嬉戏玩耍。</p>\n<p><a href=\"http://www.designboom.com/architecture/jun-igarashi-korogaru-park-in-nature-sapporo-hokkaido-japan-ycam-interlab-02-18-2016/\">设计者五十岚淳表示</a>他特意打破常规设计，是为了鼓励孩子们“更自由、更出于本能地与游乐场互动”。他认为，当孩子们在自然状态中玩耍，充分发挥他们的想象力，他们会发现更多新奇有趣的玩乐方式，就像在森林中一样。</p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171646HRrK2cZkMjhIS71q.jpg\" alt=\"\" data-ratio=\"0.6393643\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171646IMYxduohNjw4DLG3.jpg\" alt=\"\" data-ratio=\"0.66625917\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<p>作为一个建筑师，Jun Igarashi 的建筑和室内项目也颇有想法，空间富有变化，内外空间以有趣的方式相隔离、相联系。以下是一些例子。</p>\n<p>北海道富田农场的入口处。<a href=\"http://jun-igarashi.com/en/works/040signal_barn.html\">图片来自Jun Igrashi</a>。</p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171647gGSIv3pqsyDtwfT9.jpg\" alt=\"\" data-ratio=\"0.799511\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171648FHuJUimlZcKo47Nz.jpg\" alt=\"\" data-ratio=\"0.69804401\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<p>札幌一座围绕双重旋转楼梯建成的三层住宅，内部设计。图片来自<a href=\"http://jun-igarashi.com/en/works/058case.html\"> Jun Igrashi</a></p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171648w0n9W4GqeELvAOlJ.jpg\" alt=\"\" data-ratio=\"0.66625917\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171649VqC2PEU6F8DxeajR.jpg\" alt=\"\" data-ratio=\"0.74572127\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<p>一座面积 30 平米，结构十分特殊的画室。整齐排列的门令空间有种神秘气息。图片来自 <a href=\"http://jun-igarashi.com/en/works/042small_atelier.html\">Jun Igrashi</a></p>\n<div class=\"com-insert-images medium-insert-images-wide\">\n<figure class=\"placeholder\"></figure><figure class=\"\">\r\n    <img src=\"img/uploads/2016060717164998IZyjb5vGYXPOeD.jpg\" alt=\"\" data-ratio=\"0.56666667\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171649Gb6qKHX2izDwmvNW.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66111111\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images medium-insert-active\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607171650hguqvWZys35ezQHN.jpg\" alt=\"\" data-ratio=\"0.66111111\" data-format=\"jpeg\">\r\n</figure></div>\n<p>图片来源：<a href=\"http://jun-igarashi.com/en/works/064KorogaruPark.html\">Jun Igrashi</a></p>\n\n\n"}