0.0px 0.0px 0.0px; font: 14.0px 'Heiti SC Light'; color: #323333; -webkit-text-stroke: #323333} p.p13 {margin: 0.0px 0.0px 0.0px 0.0px; font: 14.0px 'Heiti SC Light'; color: #323333; -webkit-text-stroke: #323333; min-height: 14.0px} p.p14 {margin: 0.0px 0.0px 0.0px 0.0px; font: 16.0px 'Lantinghei SC'; color: #373c40; -webkit-text-stroke: #373c40} span.s1 {font-kerning: none} span.s2 {font: 16.0px 'Lantinghei SC'; font-kerning: none} span.s3 {font: 14.0px 'Microsoft YaHei'; font-kerning: none; color: #393939; -webkit-text-stroke: 0px #393939} span.s4 {font: 14.0px Times; font-kerning: none} span.s5 {font: 14.0px 'Songti SC'; font-kerning: none} span.s6 {font: 48.0px 'Helvetica Neue'; font-kerning: none} span.s7 {font: 48.0px 'Heiti SC Light'; font-kerning: none} span.s8 {font-kerning: none; background-color: #f9f9f9} span.s9 {font: 20.0px 'PT Serif'; font-kerning: none; background-color: #f9f9f9} span.s10 {font: 18.0px 'Songti SC'; font-kerning: none; color: #323333; -webkit-text-stroke: 0px #323333} span.s11 {font: 18.0px Georgia; font-kerning: none; color: #323333; -webkit-text-stroke: 0px #323333} span.s12 {font: 20.0px 'Songti SC'; font-kerning: none; color: #4c4c4c; -webkit-text-stroke: 0px #4c4c4c} span.s13 {font: 14.0px Arial; font-kerning: none} span.s14 {font: 14.0px 'Heiti SC Light'; font-kerning: none} span.s15 {font: 14.0px 'Heiti SC Light'; font-kerning: none; color: #323333; -webkit-text-stroke: 0px #323333} span.s16 {font-kerning: none; color: #373c40; -webkit-text-stroke: 0px #373c40} </style>  </p><h3>明星又代言了啥</h3><p><a href=\"http://www.adquan.com/post-2-42395.html\" rel=\"nofollow\"><b> Beats by Dre 宣布吴亦凡成为全球品牌代言人。</b></a>此前吴亦凡与 Beats 多有合作，一副吴亦凡明星定制全球限量版 Beats 耳机曾在芭莎慈善夜拍出 8.2 万人民币的价格。</p><div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20171018114114ns5ramLvdtVizU8Q.png\" alt=\"\" data-ratio=\"0.814532\" data-format=\"png\">\r\n</figure></div><p><b><a href=\"https://www.digitaling.com/projects/23608.html\" rel=\"nofollow\">陈伟霆成为必胜客全新品牌代言人</a></b>，宣传新品意大利传统薄底披萨。每年必胜客都会定时定点地宣布明星代言人+新品，但至少从业绩上看，这样逐渐形成套路的营销思路市场反响一般。<br></p><div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20171018114604a18K63CHkqomZLlc.gif\" alt=\"\" data-ratio=\"0.563333\" data-format=\"gif\">\r\n</figure></div><h3 nocleanhtml=\"true\">值得一提的案例</h3><p><a href=\"http://www.madisonboom.com/2017/10/17/mercedes-benz-king-of-the-city-jungle/\" rel=\"nofollow\"><b>奔驰 S-class 新广告，把职场精英拍成了暴躁的狮子</b></a>，抓住生活、工作和驾驶中令人烦躁的点演绎出来。但对于为什么一启动奔驰智能技术（mood changing technology）就能一键调节情绪，处理得有点突兀。</p><div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"https://v.qq.com/iframe/player.html?vid=h05628dmiaf&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\"></iframe>\r\n\t</figure>\r\n\t\r\n</div><p><a href=\"http://www.adweek.com/creativity/a-giant-new-billboard-in-london-knows-what-car-you-drive-and-even-how-youre-feeling/\" rel=\"nofollow\"><b>伦敦西区地标性的户外广告牌 Piccadilly Lights 加入了一项新功能</b></a>，通过内置相机分析过路的车辆、品牌、型号和颜色，可以对特定人群进行广告投放。</p><div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20171018115136ajACh2X9cvDu4Mlb.gif\" alt=\"\" data-ratio=\"0.429167\" data-format=\"gif\">\r\n</figure></div><p><a href=\"http://www.adweek.com/brand-marketing/lebron-james-is-out-for-revenge-in-this-epic-nike-ad-voiced-by-idris-elba/\" rel=\"nofollow\"><b>为了庆祝勒布朗·詹姆斯复出，Nike 发布一支史诗级大片</b></a>，把詹皇形容为归来的雄狮。作为手下王牌的代言人，勒布朗·詹姆斯此前在六月份的冲冠失败对 Nike 是沉痛一击。</p><div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20171018115653iYc4el91FLyTQjBN.png\" alt=\"\" data-ratio=\"1.034810\" data-format=\"png\">\r\n</figure></div><p><b>以及，<a href=\"https://mp.weixin.qq.com/s/sBPbbT7oz_6tIKIfGojMoA\" rel=\"nofollow\">Nike 发布 NBA 新赛季营销 “Want it All”</a></b>，中文版是“当出手，绝不让” 。2 分钟的新赛季广告讲述了一个篮球少年从社区到 NBA 球场，对成为超级球星的全套想象。</p><div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20171018120401KqczPswrnCOD7R46.gif\" alt=\"\" data-ratio=\"0.715000\" data-format=\"gif\" class=\"\">\r\n</figure></div><p><a href=\"https://www.digitaling.com/projects/23581.html\" rel=\"nofollow\"><b>别克 VELITE 5 和生活美学平台良仓合作</b></a>，拍摄了《从好到美好》系列微纪录片。共分为：电动少年、对折人生、听见世界和自然生长四个部分，都是通过技术或者创意将生活变得更美好的案例。</p><div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"https://v.qq.com/iframe/player.html?vid=i0524z11iei&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\"></iframe>\r\n\t</figure>\r\n\t\r\n</div><p><a href=\"https://www.digitaling.com/projects/23604.html\" rel=\"nofollow\"><b>支付宝为小商户拍了支阿卡贝拉广告</b></a>，最后 50 秒改编自北京小曲《探清水河》。除了 MC 天佑和壮声人声乐团，小商户也出镜了。</p><div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"https://v.qq.com/iframe/player.html?vid=c0562psmlas&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\"></iframe>\r\n\t</figure>\r\n\t\r\n</div><h3>最后，也挺重要</h3><p><b><a href=\"http://www.sportsmoney.cn/article/72548.html\" rel=\"nofollow\">百岁山成为澳网的全球合作伙伴</a>，</b>这是澳网有史以来第一次与中国食品饮料品牌合作。澳网虽已有 100 多年的举办历史，但也是四大满贯赛事中最年轻的。随着 2014 年李娜历史性地在澳网夺冠，越来越多亚太地区的球迷开始关注澳网。百岁山目前已服务了乒乓球团体世界杯赛、北京奥运会、中国网球公开赛、上海网球大师赛、北京浪琴表马术大师赛、中国杯帆船赛等多项大型体育赛事。</p><p class=\"\">题图来源：Beats</p>"}