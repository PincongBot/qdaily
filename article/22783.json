=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>为了吸引更多旅行者前往旅游，以更亲和的方式展现当地特色，日本冲绳县石垣岛于 2013 - 2015 年发起了一项名为“<a href=\"http://usioproject.com/\">The USIO Project</a>”的计划，将本地商户和设计师联系在一起，让双方互相合作，一起对石垣岛进行重新包装和设计。“Usio”这个词语有潮水的意思，在这里它的含义就是希望能通过这项计划吸引人们如海潮般来到这座岛上。</p>\n<p>这次 USIO 计划的一项重要内容就是邀请设计师为岛上十种特产和纪念品重新设计包装。这些包装风格颜色鲜艳，清新活泼，有明媚的海岛风情。比如说其中一个产品是本地种植的花草茶，茶盒包装像一个个小房子，组合在一起有种村落生活的感觉。另外，石垣岛在日本八重群岛的南方，西邻中国东海，离台湾很近，<a href=\"http://usioproject.com/about\" style=\"background-color: rgb(255, 255, 255);\">用主办方的说法</a>，“这里独特的本地文化由琉球、日本和台湾的文化融合而成”，所以你也能从产品中看到这个特点。</p>\n<p>项目由日本的 <a href=\"http://www.loftwork.com/\">Loftwork</a> 公司运营管理。这家公司为艺术家和设计师提供网络平台，联合一批艺术家和设计师来为日本本地工农业做设计。他们的工作内容很丰富，包装设计，网站设计，活动策划，空间规划都包括在内。USIO 计划的第一阶段是通过竞赛邀请设计师为石垣岛设计包装，最后呈现的包装是投稿中的胜选方案，会投入使用，产品在岛上能买到。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110913t8huAoi2nHlTDFX7.jpg\" alt=\"\" class=\"\" data-ratio=\"0.625\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">最终获选的产品，都很漂亮</div></figcaption></figure></div>\n<div class=\"com-insert-images medium-insert-images-wide\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110913hgBdN7YczAiKlfvS.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66809422\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">玄米奶茶</div></figcaption></figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702110914Lwpc9mfhyt7u4xHC.jpg\" alt=\"\" class=\"\" data-ratio=\"0.68669951\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">冲绳泡盛酒</div></figcaption></figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702110914HVlWjsPTLZFxOwy6.jpg\" alt=\"\" class=\"\" data-ratio=\"0.65391969\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">胶带</div></figcaption></figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110915lFHxuUq4YJgt0Mwo.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66699219\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">姜糖浆</div></figcaption></figure>\n</div>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110915gZfv92woAuYOeHm0.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66716418\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">海盐</div></figcaption></figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110915pXf53cImBhOSu1qF.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66826923\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">凤梨</div></figcaption></figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110916KChX4aPiczOSFLl5.jpg\" alt=\"\" class=\"\" data-ratio=\"0.65462963\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">花草茶</div></figcaption></figure></div>\n<p>另外，他们还邀请公众重新“探索石垣岛之旅”，希望人们能想到新的在岛上旅游的方式，并分享出自己的旅游计划。这些计划将被用在后续的旅游产品中。主办方特地为此设计了一个网站（点击<a href=\"http://usioproject.com/ishigakinow/\">这里</a>查看），网站设计得很简单，但不妨碍你从中感受到石垣岛美好的风土人情。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110916VnIzhXf6ZGJHT9dj.jpg\" alt=\"\" data-ratio=\"0.66991342\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110917HAjz3FMn5Tm7I0Zf.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110917EoCxuHpgLwVzy4lv.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702110918oFRsWgpB3POlTk7m.jpg\" alt=\"\" data-ratio=\"0.66805556\" data-format=\"jpeg\">\r\n</figure></div>\n<p>          <!--[if gte mso 9]><xml>  <w:WordDocument>   <w:View>Normal</w:View>   <w:Zoom>0</w:Zoom>   <w:TrackMoves></w:TrackMoves>   <w:TrackFormatting></w:TrackFormatting>   <w:PunctuationKerning></w:PunctuationKerning>   <w:DrawingGridVerticalSpacing>7.8 磅</w:DrawingGridVerticalSpacing>   <w:DisplayHorizontalDrawingGridEvery>0</w:DisplayHorizontalDrawingGridEvery>   <w:DisplayVerticalDrawingGridEvery>2</w:DisplayVerticalDrawingGridEvery>   <w:ValidateAgainstSchemas></w:ValidateAgainstSchemas>   <w:SaveIfXMLInvalid>false</w:SaveIfXMLInvalid>   <w:IgnoreMixedContent>false</w:IgnoreMixedContent>   <w:AlwaysShowPlaceholderText>false</w:AlwaysShowPlaceholderText>   <w:DoNotPromoteQF></w:DoNotPromoteQF>   <w:LidThemeOther>EN-US</w:LidThemeOther>   <w:LidThemeAsian>ZH-CN</w:LidThemeAsian>   <w:LidThemeComplexScript>X-NONE</w:LidThemeComplexScript>   <w:Compatibility>    <w:SpaceForUL></w:SpaceForUL>    <w:BalanceSingleByteDoubleByteWidth></w:BalanceSingle