ked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */ table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:12.0pt; \tfont-family:Cambria; \tmso-ascii-font-family:Cambria; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Cambria; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->    </p>\n<h2>书籍介绍</h2>\n<p>如果你正在读设计系，并在为未来迷茫着，不妨读读这本书——《Don’t get a Job, Make a Job》。对许多设计系的年轻人来说，毕业后找份工作是最简易的安全路线了，然而“有工作就意味着安全”的时代已一去不复返。现在的社会对设计系毕业生提出了更高的要求——他们不仅是未来的设计师，还得是下一代的企业家、设计思想家和多文化搅拌器。</p>\n<p>《Don’t get a Job, Make a Job》是 Gem Barton 写的一本书，Barton 是一位设计作家和学者，她有着十年设计教师经验，目前是 Brighton University 大学的高级讲师。</p>\n<p>在这本书中，她系统地介绍了设计系学生未来可能从事的工作，并鼓励学生们去开拓创造性的事业。“你们不应该等待——聪明人早已走出去了。他们有着独立的思想，并给自己创造了机会。”</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702144926f1VgnZzOcGNA4xC9.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66712707\" data-format=\"jpeg\">\r\n<figcaption class=\"\">书籍内页</figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/2016070214492752uXfcEDaLeSVdN9.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66712707\" data-format=\"jpeg\">\r\n<figcaption class=\"\">内页</figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702144927usBzgMmOpQn2KVGR.jpg\" alt=\"\" data-ratio=\"0.66712707\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702144927GmOYHpTf90SWK3lv.jpg\" alt=\"\" class=\"\" data-ratio=\"0.667\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702144928cs2XOnfZRI1YCQM0.jpg\" alt=\"\" class=\"\" data-ratio=\"0.667\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702144928uirVyJaUtlHL3mIk.jpg\" alt=\"\" data-ratio=\"0.667\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702144929lv4xyf8gSrCAnowL.jpg\" alt=\"\" class=\"\" data-ratio=\"0.667\" data-format=\"jpeg\">\r\n<figcaption class=\"\">书籍内页</figcaption></figure></div>\n\n"}