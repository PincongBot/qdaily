loads/201903041408447H2bG3ZMASkvlfWw.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140846yQA6zMlN315rwVXh.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140846Za6iK1PuQ8TrbWBl.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140847gxp3cYKEBdDzrIyl.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201903041408474PpIMwiemRyCv2Vt.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201903041408483cAUey4EHrG9TVSK.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140849QPoIaSMezXqCs1i2.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140849mlPVFQ96WiDqSpkC.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140845xuIshZUkOi2tl0Y8.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140849hFAn0bS3xk6Wqrly.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140849NDxgswy1OAuSLrie.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304140850S0shjp3rt7bAYxZE.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure></div><p><strong><a href=\"https://wwd.com/runway/fall-ready-to-wear-2019/paris/nina-ricci/review/\" rel=\"nofollow\">&nbsp;Nina Ricci 2019 秋冬：</a><br></strong></p><p>Nina Ricci 的两位创意总监&nbsp;Rushemy Botter 和 Lisi Herrebrugh 去年 8 月刚上任，这是他们首次亮相。两人此前因具有加勒比海文化特色的中性男装品牌&nbsp;Botter 获得大量关注，并且曾入围 LVMH 大奖决赛。<br></p><p>新系列中有大量西装造型，但多变且在阳刚和女性化之间把握适宜。Herrebrugh 对 <em>WWD</em> 说：“肩部不能做得太直，要有些倾斜，这样攻击性才不会过强。”</p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201903041411001bY7J04rLXigPmAK.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141051JWqIOFwDrxNbGTzA.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141051V5xSrn0bmX71kytT.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141052wP60ceoabgOjWk1s.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141052vf5OdcKagxm8wNSH.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201903041410527LeGWaNkwY2FdA0p.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141052so7uWrPcF1ZMgCxT.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141055EetpdFjrlVW2kHLT.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141056nQpMO35Sj8qeLA9s.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141057WIh3jBZf6XrKodGD.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201903041410589TCyAYn3FGoOgJl8.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141058TR0HQJsq5Wevamnx.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141100pFnWCB4YSPsIk7iv.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141101rFyKJbadVfCOwD2x.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141104kGqe5wNQ8oLl1I2p.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141102pMT4R5Xqb7meY1zs.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141104P2IJpQUN4oB7S6sE.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141102NEwJi2IKdt76g8py.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure></div><p><strong><a href=\"https://wwd.com/runway/fall-ready-to-wear-2019/paris/yohji-yamamoto/review/\" rel=\"nofollow\">Yohji Yamamoto 2019 秋冬：</a></strong></p><p>”如今的秀是为了卖衣服，这点我明白，但过去，走秀曾更多是为了造梦，然后把衣服作为售卖梦的一种可行形式。我怀念这一点，而山本耀司就是这么做的。”作为特别嘉宾出演的模特 Coco Rocha 告诉 <em>WWD</em>。</p><p>山本耀司说他在这个过程中很享受，“好像变成了一个做衣服的小女孩”。衣服边缘大多没有收边，一些线头垂落下来；有的衣服上画着稚气的涂鸦；黑色的外套、长裙以不同方式围裹人体，将其化为行走的雕塑。</p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141844fbG0kjwVAc3q7YWZ.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141844o4sUhvS6JcNgkGXL.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141844oMZv9K7LSOmVr645.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141845xl5Ka2nrMeUvkcbH.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20190304141846YG0aiDM6f1lZ8QBm.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img s