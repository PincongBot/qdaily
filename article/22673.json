nUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>最近科颜氏新推出了一个广告，在这个广告里，演员 Alec Baldwin 、模特 Hannah Davis 等明星瞬间变成了小正太和萌妹子，讲述着科颜氏的抗衰老中心有多么神奇。</p>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"http://v.qq.com/iframe/player.html?vid=f0185d705cw&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t</figure>\r\n\t\r\n</div>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"http://v.qq.com/iframe/player.html?vid=y0185cshbuh&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t</figure>\r\n\t\r\n</div>\n<p>这一系列广告是科颜氏联合最近上映的影片《超级名模2》（Zoolander）合作推出，比如广告中提到的抗衰老中心 （Derek Zoolander Center for People Who Don’t Age Good）的创意灵感就是来自于《超级名模 1》中的剧情。如果看过《超级名模》第一部，也许还会记得主人公拥有一个梦想，他希望为缺乏阅读的孩童建立一个以自己名字命名的阅读中心，也就是 Derek Zoolander Center for Kids Who Can’t Read Good。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607115907Mhk8S7mw4cElCnTj.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">小院长致辞</div></figcaption></figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607115907nRSGItCZjOvEH57X.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66720257\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">开业盛况</div></figcaption></figure></div>\n<p>这次《超级名模》推出第二部，科颜氏便在上周借着这个噱头大张旗鼓地在纽约开设了一家抗衰老中心。开业典礼上还请到了“小孩院长”致辞，也是想说明来到这个抗衰老中心接受科颜氏独家订制的“年轻修复计划”，就可以脱离衰老。</p>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"http://v.qq.com/iframe/player.html?vid=a0185taxypr&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t</figure>\r\n\t\r\n</div>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe frameborder=\"0\" src=\"http://v.qq.com/iframe/player.html?vid=u0185wf9h4o&amp;tiny=0&amp;auto=0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t</figure>\r\n\t\r\n</div>\n<p>这些广告里看起来有些违和，不过也因此显得“笑果”十足。年轻童真的孩子们故作深沉地讲述着自己怎么从衰老症中走出来的故事，配以明显上了年纪的嗓音。广告里还出现“ Before ”的照片，一本正经地胡说八道着科颜氏的抗衰老奇效。</p>\n<p class=\"\">\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n</p>\n<p>实际上此前科颜氏在传统广告领域的投入很少，比如平面广告、电视广告、户外广告等都很少能看到科颜氏的身影。尽管母公司欧莱雅去年的广告费投入高达 22 亿美元，但对旗下的科颜氏的营销投入却并不多。不过科颜氏也有着自己的一套营销体系：他们非常注重社交平台，经常会让明星在其社交平台上推荐他们的产品，也经常会邀请一些用户去分享他们的使用体验。去年八月淘宝出品的《十年海淘报告》显示，科颜氏成为中国消费者海淘中最主流的美妆护肤品牌。</p>\n<p class=\"\">不过找一群小孩儿来说抗衰老这件事，真的好么？</p>\n<p class=\"\">题图来自Adweek</p>\n\n\n"}