deWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>“微缩城市”是个容易令人着迷的东西，它让我们以另一种视角观看一座城市，更清楚地感知城市的不同面，留意到这个广阔空间里各个细节。不少人喜欢乐高或者看城市建设模型也是出于这个原因。</p>\n<p>可以用来搭建微缩城市的当然不只有乐高，比如说在日本，有人用的是 MUJI 的产品。2016 年 3 月至 4 月，一个大型装置将相继在 MUJI 的台北旗舰店统一阪急百货和北美旗舰店纽约第五大道店展出，这个装置是一个“微缩东京”，用 10000 件 MUJI 的产品搭建出东京这座大都市，名为“东京的 10000 种样子（MUJI 10000 Shapes of Tokyo）”。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141526A8WSfBlgPDcmHYsK.gif\" alt=\"\" class=\"\" data-ratio=\"0.56\" data-format=\"gif\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">微缩东京</div></figcaption></figure></div>\n<div class=\"com-insert-embed com-insert-embeds\">\r\n\t<figure style=\"margin:0;\">\r\n\t\t<iframe src=\"http://player.youku.com/embed/XMTQ4OTQ0OTA3Ng==\" frameborder=\"0\" allowfullscreen=\"\" style=\"width: 100%; min-height: 240px;\"></iframe>\r\n\t</figure>\r\n\t\r\n</div>\n<p>这个装置由日本创意机构 <a href=\"http://dotby.jp/\">dot by dot</a> 联合 <a href=\"http://tasko.jp/about/\">TASKO</a> 工作室共同完成。他们用到了各种你可能想象不到的 MUJI 产品来打造这个微缩版的东京，从铅笔橡皮这样的文具，到书签绳时钟这样的小物，再到收纳盒、置物架，MUJI 这些产品就像最基本的建筑材料，一点一点地砌成城市。或许是因为 MUJI 的产品设计得小巧简洁，且风格统一，适合整齐地排列、堆叠，所以用来做“建筑材料”刚刚好。</p>\n<p>在这座微缩东京中，我们可以看到城市里的桥梁、高楼、庙宇，还有涩谷十字路口、东京塔这样标志性的地点。但如果不仔细看，你很难想象出它们都是用什么做成的。</p>\n<p>比如说东京塔，用到六角双头水性笔、化妆盒和抽屉整理盒；颜色层次最丰富的寺庙，包括了木制置物筒、硬质封面相本、自动铅笔芯、印度棉手织杯垫、聚酯纤维圈绒地毯；用来造桥的是不锈钢吊挂式淋浴架、胶带台、信件收纳架等等。这个项目的官方网站一一列出了所使用的 MUJI 产品，想更进一步了解可以点击<a href=\"http://tokyo.muji.com/\">这里</a>查看。</p>\n<div class=\"com-insert-images medium-insert-images-wide\">\n<figure class=\"\">\r\n    <img src=\"img/uploads/20160702141528bRkPVWSagd5Y3Cyc.jpg\" alt=\"\" data-ratio=\"0.56333333\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141528atEgXqMY9AoTKN7z.jpg\" alt=\"\" class=\"\" data-ratio=\"0.58777778\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">涩谷十字路口</div></figcaption></figure>\n</div>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141528HyE6iBGJg47cmnRP.jpg\" alt=\"\" data-ratio=\"0.56333333\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141529KRDmrOS6bU4C5ze1.jpg\" alt=\"\" class=\"\" data-ratio=\"0.54666667\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">寺庙</div></figcaption></figure>\n</div>\n<div class=\"com-insert-images multiple\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141529rIC2jBqhT4tazZQS.jpg\" alt=\"\" class=\"\" data-ratio=\"0.33240741\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">桥</div></figcaption></figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702141530BsmzUv4TlDnqfK3Q.jpg\" alt=\"\" class=\"\" data-ratio=\"0.5\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">东京市政府</div></figcaption></figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702141530GjzTX4vgkdKNPcEm.jpg\" alt=\"\" class=\"\" data-ratio=\"1.0\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">东京塔</div></figcaption></figure>\n</div>\n<p>这个项目属于 MUJI 和东京市合办的 <a href=\"https://andtokyo.jp/en/logocampaign/\">&amp;Tokyo</a> 推广活动。为了宣传东京奥运会，东京市希望能强化自己的城市品牌，让更多人了解东京。去年 10 月，东京公布了自己的新城市 Logo “&amp;Tokyo”，意思是东京在以各种方式与人们，与世界建立起沟通和联系，可以是“Coffee &amp; Tokyo（咖啡与东京）”、“Fashion &amp; Tokyo（时尚与东京）”“Art &amp; Tokyo（艺术与东京）”，总之是世界与东京。</p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141531PX5raOgwyeH0CcqR.jpg\" alt=\"\" class=\"\" data-ratio=\"0.50124069\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">东京市新 Logo</div></figcaption></figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702141531BmTOexG9JS1I0gDL.jpg\" alt=\"\" class=\"\" data-ratio=\"0.27645377\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">东京与世界</div></figcaption></figure>\n</div>\n<p>MUJI 微缩东京装置将于 3 月 5 日—3 月 15 日在台北展出，3 月 19 日—4 月 26 日巡回至纽约。</p>\n<p>视频来源：<a href=\"https://www.youtube.com/watch?v=8_Uxc4uLlOM\">MUJI Global</a></p>\n<p>图片来源：<a href=\"http://tokyo.muji.com/\">Tokyo MUJI</a>，<a href=\"http://www.spoon-tamago.com/2016/03/02/tokyo-city-recreated-using-10000-muji-products/\">spoon-tamago</a>，<a href=\"https://andtokyo.jp/en/brand/\">andtokyo</a></p>\n\n\n"}