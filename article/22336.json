den=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>一提到糖果，许多人都觉得那是专属于小孩子的。不过这家名叫 Sweet Saba 的糖果店却要为大人们打造专属于他们的糖果，于是便有了这些像钻石、水晶、劳力士表、口红一样的鲜艳糖果。</p>\n<div class=\"com-insert-images\">\n<figure class=\"\">\r\n    <img src=\"img/uploads/20160702113633ej5q1IzQukgO7Nt2.jpg\" alt=\"\" data-ratio=\"0.66728625\" data-format=\"jpeg\">\r\n</figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702113634KXO9plnuYsLHVUhk.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure><figure class=\"placeholder\"></figure>\n</div>\n<div class=\"com-insert-images\"></div>\n<p>制作这些精美糖果的店主 Maayan Zilberman 希望大人们能喜欢她的糖果，在这些糖果里看到他们一直喜欢的、向往着的东西。比如这些形状各异的水晶糖果，Zilberman 解释称：“水晶和钻石之所以特别，是因为它们与众不同，我也希望我的糖果每一个都是独一无二的。”纽约时报曾经称赞这些糖果“像是从硬糖山上采来的碎片，有鲜艳的色彩漩涡、尖凸的轮廓，经常还撒着金色的碎屑”。</p>\n<div class=\"com-insert-images\">\n<figure class=\"\">\r\n    <img src=\"img/uploads/20160702113634ocbxaOZKSkL9WFnD.jpg\" alt=\"\" class=\"\" data-ratio=\"0.75066667\" data-format=\"jpeg\">\r\n</figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702113635iTfcX39Jt5UsMoer.jpg\" alt=\"\" class=\"\" data-ratio=\"0.75066667\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images medium-insert-active\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702113635xAWmH2YcMagsl7ET.jpg\" alt=\"\" class=\"\" data-ratio=\"0.75066667\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">水晶系列糖果，一套 5-8 个，价位在 20-40 美元不等。</div></figcaption></figure></div>\n<p>尽管去年 11 月刚刚在 Fort Gansevoort 开设了第一家临时店，但 Sweet Saba 已经积累了一批优质客户。Sweet Saba 的糖果出现在了金球奖的颁奖晚宴上。店主  Zilberman 为此精心制作了口红、香水样式的糖果。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702113636omjne4wqJZfap0hR.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure></div>\n<p>还有一些音乐节的名人从 Sweet Saba 这里订购磁带样式的糖果送给自己的朋友。这些磁带一般是通过模具制作，最后的上色部分是 Zilberman 亲自上手描绘而成。</p>\n<div class=\"com-insert-images\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021136369z1dfWCqJD5Q0NYS.jpg\" alt=\"\" class=\"\" data-ratio=\"0.75066667\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702113637ShVLZAI90scRH2OP.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure>\n</div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702113637N2LHXCnMfvcig96G.jpg\" alt=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n</figure></div>\n<p>除此之外，还有充满时尚感的墨镜系列和劳力士表系列。这些都是圣诞、新年和情人节的热卖品。不光是形状好看，在口味方面也多种多样。Sweet Saba 的糖果与食品技师合作，开发了包括泡泡糖味、威士忌味、牛奶味的 30 多种口味。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021136389ivaZst0KqREdljm.jpg\" alt=\"\" data-ratio=\"0.75066667\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n</p>\n<div class=\"com-insert-images\"><figure class=\"\">\r\n    <img src=\"img/uploads/20160702113639vRThjwP54YCo3JZ0.jpg\" alt=\"\" data-ratio=\"0.75066667\" data-format=\"jpeg\">\r\n</figure></div>\n<p>令人惊讶的是，店主 Zilberman 的制糖手艺完全是自学的，Zilberman 说 YouTube 这样的视频平台上提供了许多免费的教学课程，总是能给她许多灵感。这位美女店主的履历可不一般，她之前做过内衣和蛋糕，每一个生意她都干得不赖。我们曾介绍过这位店主开设糖果店背后的一些故事，可以在文后延伸阅读部分看到。<br></p>\n<p class=\"\">题图来自 Sweet Saba</p>\n\n"}