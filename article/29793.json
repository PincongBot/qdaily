figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719103302spOjdSfM7YQ0quNe.jpg\" alt=\"\" data-ratio=\"0.757813\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719103302TZ23zKLR74OMIl0Y.jpg\" alt=\"\" data-ratio=\"0.757813\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719103303OawbKY01cHsRxzI6.jpg\" alt=\"\" data-ratio=\"0.757813\" data-format=\"jpeg\">\r\n</figure></div><p><a href=\"http://wwd.com/runway/mens-spring-collections-2017/new-york/siki-im/review/\" rel=\"nofollow\">Siki Im 春夏男装系列</a>：</p><div class=\"com-insert-images medium-insert-images-wide\"><p></p><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607190933404QlwrzObyVZaTUMC.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\" class=\"\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719093348lbofpCtK6YjZczD8.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719093349BQ94pJFngzdCEGM6.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607190933509Su3nmxD16HZLKMj.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719093351DV049yJRK5jqU2be.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719093356s8VgEATRjIFProax.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160719093357fA2KVQXIrecFyxap.jpg\" alt=\"\" data-ratio=\"0.669100\" data-format=\"jpeg\">\r\n</figure></div><p><br></p>"}