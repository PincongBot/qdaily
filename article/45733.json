: #333333} span.s1 {font-kerning: none} span.s2 {text-decoration: underline ; font-kerning: none; color: #326891; -webkit-text-stroke: 0px #326891} span.s3 {font-kerning: none; background-color: #ffffff} span.s4 {font: 13.0px Arial; font-kerning: none; background-color: #ffffff} span.s5 {font: 18.0px 'Arial Unicode MS'; font-kerning: none} span.s6 {font: 13.0px Georgia; font-kerning: none} span.s7 {text-decoration: underline ; font-kerning: none; color: #0000ff; -webkit-text-stroke: 0px #0000ff} span.s8 {font: 13.0px Georgia; font-kerning: none; background-color: #ffffff} span.s9 {text-decoration: underline ; font-kerning: none; color: #0000ff; background-color: transparent; -webkit-text-stroke: 0px #0000ff} </style>"}