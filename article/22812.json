deWhenUsed=\"false\" Name=\"Medium List 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>伦敦地铁是很受世界关注的城市地铁，它地处伦敦这座国际大都市，这是部分原因，但也因为这里总有有意思的事情发生，人们常常围绕它提出很妙的想法。比如说地铁站内的告示牌，经常有意无意地表达立场，完全是经典英式幽默的缩影（<a href=\"http://www.qdaily.com/articles/19596.html\">“逃票者，必被剧透星战剧情”</a>）。跟它有关的设计也不少，除了常规的<a href=\"http://www.qdaily.com/articles/2760.html\">车辆设计</a>，设计师对于<a href=\"http://www.qdaily.com/articles/17524.html\">地铁图</a>、<a href=\"http://www.qdaily.com/articles/14671.html\">改造地铁通道</a>和<a href=\"http://www.qdaily.com/articles/6044.html\">废弃线路</a>，都有创新的提案。</p>\n<p>也许没有谁会专门表白说我就是爱伦敦地铁，那毕竟太 drama 了点，但很多人确实对它是有点感情、好奇和向往的，哪怕这仅仅是地铁。如果你是这群人中的一个，那你可能很喜欢下面这组关于伦敦地铁的海报。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125028hH4MKYjrdV2v0bJI.jpg\" alt=\"\" data-ratio=\"0.70740741\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125029AvgwjmVEk9TXJKLe.jpg\" alt=\"\" class=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure></div>\n<p>这组共 11 张海报出自澳大利亚平面设计师 <a href=\"http://www.nickbarclaydesigns.com/\">Nick Barclay</a> 之手。海报风格极为简洁，但是颜色鲜艳，信息很丰富。每幅海报上是一条地铁线路，颜色对应该线路在地铁系统中的颜色，并且附上与之有关的事实。</p>\n<p>从一张海报中你会知道线路形状是怎样的，你会了解到这一站开通的时间，有多少站，具体是哪些站，过去有哪些站，线路的长度以及承载的人数。在看这个海报之前，我从来没意识到 Waterloo &amp; City 线这么短，只有 Bank 和 Waterloo 两站，而跨区的 District Line 就很长，足足 60 站。每年夏天都很多人乘这条线到伦敦的南边看温网公开赛。</p>\n<p class=\"\">以下多图预警。</p>\n<div class=\"com-insert-images medium-insert-images-wide\">\n<figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125029yCgj39d0lqrNLYEo.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure><figure class=\"\">\r\n    <img src=\"img/uploads/20160702125030DFcBIZJKisuLhePE.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125030I09UsSja7iEnYpxZ.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125031sDPtuCOB8HXvGgZW.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201607021250319aogiIsyFlEkSHeb.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125031bUD7cmn80MsTBpdz.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125032PZozvuFpNq3OKJU1.jpg\" alt=\"\" class=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">  以下为其中一部分地铁海报，更多设计请移步其<a href=\"http://www.nickbarclaydesigns.com/graphic-design/\" style=\"background-color: rgb(255, 255, 255);\">官网</a>\n</div></figcaption></figure>\n</div>\n<p>Nick Barclay 是位颇有名气的平面设计师，因为他的风格真的很强烈。大部分设计作品都可以形容为极简，只用最简单的颜色、几何图形和线条来表达意思。有时候这些设计简单而意义明确，有时候则让人困惑，也可能你想了好一会，但在最后猜到的时候不得不感叹它的妙处。</p>\n<p>他其他作品包括《星球大战》角色系列，每一幅海报代表一个角色，但只用三种颜色来刻画。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125032FL13wgSoJcNq2Z64.jpg\" alt=\"\" data-ratio=\"0.70740741\" data-format=\"jpeg\">\r\n</figure></div>\n<p>鸡尾酒系列。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125033Xg5MmurckOLNho3V.jpg\" alt=\"\" data-ratio=\"0.70740741\" data-format=\"jpeg\">\r\n</figure></div>\n<p>去年我们还介绍过 Nick Barclay 的<a href=\"http://www.qdaily.com/articles/14383.html\">极简品牌 Logo</a>。Barclay 对这套设计的说法是：“Logo 在人们心里已经根深蒂固，我希望打破它们并极简化，看看人们是否依然能从中辨识出这些品牌的原型。”</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125033ApRVgwhU67P3YfKQ.jpg\" alt=\"\" data-ratio=\"3.74907407\" data-format=\"jpeg\">\r\n</figure></div>\n<p>以及<a href=\"http://www.qdaily.com/articles/6793.html\">电影海报</a>，用圆形表达一切。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702125034TWUn3CfMGFHVYcuw.jpg\" alt=\"\" data-ratio=\"0.70666667\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n</p>\n<p>图片来源：<a href=\"http://www.nickbarclaydesigns.com/graphic-design/\" style=\"background-color: rgb(255, 255, 255);\">Nick Barclay Designs</a><br></p>\n\n"}