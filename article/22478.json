n Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>去年秋天的时候，平面设计师 Alex Henderson 和朋友踏上了去日本的旅途。他们在那里呆了一个多星期，游走在东京的地铁、居酒屋、神社和庆典队伍之间。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702123610CRmselEWM4OGx1Hk.jpg\" alt=\"\" class=\"\" data-ratio=\"0.66666667\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">Alex Henderson 在日本 / Dinesh Dave 摄</div></figcaption></figure></div>\n<p>这一周的经历让 Alex 对日本文化开始着迷，回到美国之后，他整理出 400 多张照片，决定根据自己在日本的所见做一张实体海报。</p>\n<p class=\"\">他热爱在东京随处可见的指示标，觉得它们十分特别。“不仅仅是因为那些令人意想不到的色彩组合或是特立独行的符号，更多是因为那些标志常常有化繁为简的魔力。”</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702123610ipIodBlqGvsZQRHX.gif\" alt=\"\" data-ratio=\"0.55092593\" data-format=\"gif\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160702123611PLVK1RDUfkxcarW5.jpg\" alt=\"\" class=\"\" data-ratio=\"0.75\" data-format=\"jpeg\">\r\n<figcaption class=\"\"><div style=\"text-align: center;\">和田三造 《配色事典―大正・昭和の色彩ノート》</div>\n<p>        <!--[if gte mso 9]><xml>     <o:AllowPNG></o:Allo