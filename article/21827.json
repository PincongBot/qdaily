 UnhideWhenUsed=\"false\" Name=\"Medium Shading 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"65\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"66\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium List 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"67\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 1 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"68\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 2 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"69\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Medium Grid 3 Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"70\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Dark List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"71\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Shading Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"72\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful List Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"73\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" Name=\"Colorful Grid Accent 6\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"19\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"21\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Emphasis\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"31\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Subtle Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"32\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Intense Reference\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"33\" SemiHidden=\"false\"    UnhideWhenUsed=\"false\" QFormat=\"true\" Name=\"Book Title\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"37\" Name=\"Bibliography\"></w:LsdException>   <w:LsdException Locked=\"false\" Priority=\"39\" QFormat=\"true\" Name=\"TOC Heading\"></w:LsdException>  </w:LatentStyles> </xml><![endif]-->  <!--[if gte mso 10]> <style>  /* Style Definitions */  table.MsoNormalTable \t{mso-style-name:普通表格; \tmso-tstyle-rowband-size:0; \tmso-tstyle-colband-size:0; \tmso-style-noshow:yes; \tmso-style-priority:99; \tmso-style-qformat:yes; \tmso-style-parent:\"\"; \tmso-padding-alt:0cm 5.4pt 0cm 5.4pt; \tmso-para-margin:0cm; \tmso-para-margin-bottom:.0001pt; \tmso-pagination:widow-orphan; \tfont-size:10.5pt; \tmso-bidi-font-size:11.0pt; \tfont-family:\"Calibri\",\"sans-serif\"; \tmso-ascii-font-family:Calibri; \tmso-ascii-theme-font:minor-latin; \tmso-hansi-font-family:Calibri; \tmso-hansi-theme-font:minor-latin; \tmso-bidi-font-family:\"Times New Roman\"; \tmso-bidi-theme-font:minor-bidi; \tmso-font-kerning:1.0pt;} </style> <![endif]-->      </p>\n<p>俄罗斯设计工作室 <a href=\"http://52factory.ru/\">52 Factory</a> 的两位设计师 Nasya Kopteva 和 Sasha Braulov 时常设计一些有趣的家居用品，建筑廓形的木质小摆件，风格华丽的插画手机壳等。他们最近又完成了一套桌面摆件，包括卷笔刀、手机座、名片夹、便笺座、笔架等 物品。这个系列向 19 世纪末 20 世纪早期的俄罗斯先锋派致敬，每个物品都对应该国的经典建筑。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144706NlQWkdzr4Zbsmxhf.jpg\" alt=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144706vRIQp87goLclwd2e.jpg\" alt=\"\" data-ratio=\"1.0\" data-format=\"jpeg\">\r\n</figure></div>\n<p>“俄罗斯先锋派”是俄国一次影响深远的文化与艺术思潮，盛行于 19 世纪末到 20 世纪早期，十月革命前后，参与者涵盖了艺术家，电影工作者，编剧，作曲家，以及设计师和建筑师。</p>\n<p>在这股思潮影响下诞生的先锋派建筑多被认为是“构成主义建筑”，建筑师们更自由积极地探索，同时也簇拥着基于工业化的新秩序，想要摈弃个人主义的供人愉悦的建筑，为建筑赋予更多功能性。这些建筑师注重几何体块的组合，对结构、空间的轮廓和尺度进行了更深的思索。这一点，影响了后来很多建筑师。</p>\n<p>Nasya Kopteva 和 Sasha Braulov 把这些先锋派建筑的经典作品融入到自己的设计中。从一个个小巧的桌面摆件中，你还是能看到那些结构鲜明的建筑轮廓。这些摆件都由实心橡木制成，原料回收自一家木工坊。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144711J2Gc0myv8kYU4dah.jpg\" alt=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144712NVDJcSu3plae0924.jpg\" alt=\"\" data-ratio=\"0.63333333\" data-format=\"jpeg\">\r\n</figure></div>\n<p>用于摆放回形针的小摆件，灵感来自先锋派代表人物，画家、建筑师康斯坦丁·梅尔尼科夫（ Konstantin Melnikov）的故居梅尔尼科夫住宅。他自己设计的住宅和工作室已经成为西方建筑史的经典之作。这座房子由两个相连的不规则圆柱体形成，上面布满六边形窗户，风格鲜明。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144712IgJOrMCxNGpsj6Bh.jpg\" alt=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144713m6tKU4RQGz2pdJYC.jpg\" alt=\"\" data-ratio=\"0.64\" data-format=\"jpeg\">\r\n</figure></div>\n<p>便笺座的原型是一个公交车车库，由梅尔尼科夫和另一位俄罗斯著名建筑师弗拉基米尔·舒霍夫（Vladimir Shukhov）设计，后者也是知名建筑师，我们曾报道过他设计的<a href=\"http://www.qdaily.com/articles/17188.html\">莫斯科舒霍夫塔</a>。便笺放在平缓的斜面上，使用者可以清楚地看到上面的内容，也能方便地随手做笔记。    <br></p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201606071447157Ldvn2toYJTB1waS.jpg\" alt=\"\" class=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144716WvRI9NbMtLgoUcuh.jpg\" alt=\"\" data-ratio=\"0.74626866\" data-format=\"jpeg\">\r\n</figure></div>\n<p>笔架和手机底座组合起来形成的是微缩版的纺织研究所的公用房，呈字母 H 形。纺织研究所始建于 1930 年，位于莫斯科。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144718jx4PTXFGD3lymMa2.jpg\" alt=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144719cMINXhVY9TyJpBAg.jpg\" alt=\"\" data-ratio=\"1.34048257\" data-format=\"jpeg\">\r\n</figure></div>\n<p>卷笔刀和名片夹组合则是圣彼得堡的工人文化宫。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144719erUaXndZKMgRzwjm.jpg\" alt=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<p>头尾宽度不一的尺子，模拟圣彼得堡红旗纺织厂的高大烟囱。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201606071447201zODoIhbSkgda0qC.jpg\" alt=\"\" data-ratio=\"0.71388889\" data-format=\"jpeg\">\r\n</figure></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607144721cRXxeIDTBgfjQNld.jpg\" alt=\"\" data-ratio=\"0.66533333\" data-format=\"jpeg\">\r\n</figure></div>\n<p>胶带座的设计参考了莫斯科 1930 年的建筑，一座圆形浴场。</p>\n<p>图片来源：<a href=\"http://52factory.ru/\">52 factory</a>，<a href=\"http://a-a-ah.com/city/moscow/walk/architecture\">A-a-ah</a>，<a href=\"http://www.mimoa.eu/projects/Russia/Moscow/Bakhmetevsky%20Bus%20Garage/?abvar4&amp;utm_expid=3171585-1.pFu_x39wQKuggy22EudlKA.4&amp;utm_referrer=https%3A%2F%2Fwww.google.com.sg%2F\">mimoe</a>，<a href=\"http://www.fastcodesign.com/3055810/wanted/celebrate-avant-garde-russian-architecture-with-this-wood-desk-set#3\">fastcodesign</a>，<a href=\"http://www.designboom.com/design/52-factory-russian-avant-garde-desktop-organizer-01-29-2016/\">designboom</a></p>\n\n\n"}