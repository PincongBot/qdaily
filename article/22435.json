miHidden=\"false\"  Name=\"Colorful Grid Accent 5\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Light Shading Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Light List Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Light Grid Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium Shading 1 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium Shading 2 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium List 1 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium List 2 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium Grid 1 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium Grid 2 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Medium Grid 3 Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Dark List Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Colorful Shading Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Colorful List Accent 6\" ></w:LsdException> <w:LsdException Locked=\"false\"  Priority=\"99\"  SemiHidden=\"false\"  Name=\"Colorful Grid Accent 6\" ></w:LsdException> </w:LatentStyles></xml><![endif]--></p>\n<p class=\"\">前两天，Gucci 宣布和 Florence + the Machine 的主唱 Florence 达成合作，之后 Florence 会为前者代言珠宝和腕表系列。对于乐迷来说，这个代言姗姗来迟，因为  Florence 早就在演唱会上穿过 Gucci 的衣服了，夸张点也可以说是“天作之合”。图片是这样的：  <br></p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201606071721367vpn9IQYTjPCLuSB.jpg\" alt=\"\" class=\"\" data-ratio=\"1.28205128\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">这次和 Gucci 的合作并非突发奇想，其实早在 2012 年 Gucci 创意总监还是 Frida Giannini 时，两位就有过演出服装的项目合作。而如今，由 Alessandro Michele 带来的 70 年代复古风格，和 Florence 本身的气质更加吻合。<br></p>\n<p class=\"\">据说，在两位正式见面之前，他们错开分别去了对方的酒店，并检查了对方平日的穿着风格。\r\n\r\n“我们有很多相似的地方，我们对文艺复兴和希腊神话着迷，被巴洛克式迷幻所影响”， Florence Welch 说。而 Alessandro 则表示他是听着 Florence 的歌来进行设计创作的。代言珠宝腕表也是因为\r\n\r\nFlorence 热衷首饰。她说，如果有一天她没戴任何珠宝就出门了，那一定会浑身不自在。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201606071721367Tjdzpyu9DAEorqg.jpg\" alt=\"\" data-ratio=\"1.5\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">Florence + the Machine 这个英国乐队在国内不算大众，但也有了一小批忠粉，至少你能在豆瓣找到专辑条目、小组、小站，网易云和虾米也有完整的专辑歌单。每张专辑的评分都很高，尤其是 2008 年出的首张专辑《Dog Days Are Over》，评分高达 9.1 分。<br></p>\n<p class=\"\">如果你喜欢英伦 Pop 和复古文化，可能会对这支乐队产生兴趣。他们的曲风轻快，但歌词谈论的却多是死亡、暴力和分离，这听起来有点朋克，加上主唱的气质带点神经质的性感，很容易就坠入脑残粉的行列。</p>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/20160607172137RN6boGdgnvYtxrEy.jpg\" alt=\"\" data-ratio=\"0.6\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\">Florence + the Machine 也并非仅靠颜值和噱头来赢取关注的乐队，从 2007 年创立以来，成绩斐然。2008 年的发表的两支暖身作品 Kiss With A Fist 和 Dog Days Are Over，皆挤身英国金榜百大单曲之林。在尚未正式发行专辑之前，Florence + The Machine 已率先抱回 2009 年全英音乐“最佳乐评人奖”，2009 年推出的单曲Rabbit Heart（Raise It Up）于首周便拿下英国 TOP12 的好成绩，各大传媒——The Time（4/5）+ The Observer（4/5）+ The Guardian（4/5）+ Drowned In Sound（8/10）——皆给予近满分的破表推崇。对于一支成立年份并不算太久的独立乐队来说，这样的出道经历算得上是一炮打响。</p>\n<p class=\"\">刚结束的格莱美上，\r\n\r\nFlorence 就穿上了 Gucci 带有星星月亮刺绣的粉色长裙，并且佩戴了 Gucci 的珠宝，这是其作为代言人的首次亮相。她对主持人说，红毯上静止着被无数相机拍照会感到一点不自然，舞台可能更适合我。不过，纵观 Gucci 和各大明星和代言合作，这次总算是找对人了。</p>\n<div class=\"com-insert-images\"></div>\n<div class=\"com-insert-images\"><figure style=\"margin:0;\">\r\n    <img src=\"img/uploads/201606071721372CZt6mV4oQDAwxcJ.jpg\" alt=\"\" data-ratio=\"0.80599369\" data-format=\"jpeg\">\r\n</figure></div>\n<p class=\"\"><br></p>\n\n\n"}