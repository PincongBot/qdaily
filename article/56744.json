x;\"> <img src=\"img/uploads/20180925172720bkMoY6hLmXzNwKW4.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172720kPZVa6LKIOj7WTDQ.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172721wIWNrBfPgaGoKVdb.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172721Y8yF7jkhAvBXoiUl.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172721LDwMos3vuHYZ8OGe.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172722sU3Y2z9WTXJI1Dx4.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172722Koy3Wbc6L7EO9AIR.jpg\" data-ratio=\"1.499268\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172722T45rPmxJtCQuhSfD.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201809251727232aGhnX6Z7mIvVsFb.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201809251727231Mfq0RrHQU4FxyWP.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172720dIGJmnwP5gxifcDX.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172723enAyZ6JhrqLuaFCx.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201809251727432J8xw6SdFT4ZYORv.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172742NmzV8SZs3WtTu2IP.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure></div><p><strong><a href=\"https://wwd.com/fashion-news/shows-reviews/gallery/gucci-rtw-spring-1202841367/#!1/gucci-rtw-spring-2019\" rel=\"nofollow\">Gucci 2019 春季成衣系列：</a></strong></p><p>新系列在巴黎 Théâtre Le Palace&nbsp;剧院发布，以意大利实验艺术家&nbsp;Leo de Berardinis 和 Perla Peragallo 的短片开场，中场&nbsp;Jane Birkin 还现场表演了一首 “Baby Alone in Babylon”。</p><p>服装仍然华丽非凡，放在剧院里展示就更显得戏剧化。本季延续了 2018 秋冬的主题，向 1968 年的巴黎致敬，同时又加入了一些 90 年代的美国元素，比如蛇皮纹吊带裙、印有美国乡村歌手 Dolly Parton 脸的牛仔夹克。系列中还展示了 Gucci 与迪士尼的合作，把米老鼠的头变成了充满波普感的手包。</p><p>关于政治的讨论也非常外化，一些裙子或外套上印有用法语写着的“为夏之雪定制（Tailoring for a summer of snow）”，或者“一条属于蓝色海岸之冬的裙子（A dress for winter at Côte d'Azur）”。</p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172916yvdL04qkGluYwDQ8.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925173500mSpo9IwYGXEeBCQu.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172913I24pu69aQB0WTEOJ.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201809251729121mbqit9kwvn6YVyO.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172911lEB2uGOwRJHioyNV.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172912bVepL8xncYIAguqF.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201809251729128MDwZFkPLr0ipaIJ.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180925172912KETNLxAD92h6k18W.jpg\" data-ratio=\"1.500732\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201809251729130VFOjtz7iNsfpPAr.jpg\" data-ratio=\"1.500732\" data-f