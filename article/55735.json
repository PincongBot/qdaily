5e.jpg\" data-ratio=\"1.498911\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807301344004GSjrd5YHJyf0Xeg.jpg\" data-ratio=\"1.501092\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134423Gf1TmjhL7P68dUVl.jpg\" data-ratio=\"1.500000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134437NkiZF0zf51pOKTgW.jpg\" data-ratio=\"1.501089\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134447xVBN4gulikEpcZOm.jpg\" data-ratio=\"1.500000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134459fOHtr6PkgAyqcJLe.jpg\" data-ratio=\"1.500000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134516ui6LDWYNGRbhICep.jpg\" data-ratio=\"1.498911\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134526hTpIsonMqF6kD7z2.jpg\" data-ratio=\"1.498911\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134537CRwZV4pPd0f2JkTy.jpg\" data-ratio=\"1.498911\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807301346048hw6UfCQ7OeDITSg.jpg\" data-ratio=\"1.498911\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134621yXrADHN89uRZ0QYJ.jpg\" data-ratio=\"1.500000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134639sOq3lCS9Pxpwbyvh.jpg\" data-ratio=\"1.501094\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730134653Fjw2q4C9gHY80dpf.jpg\" data-ratio=\"1.498913\" data-format=\"jpeg\"> </figure></div><p><strong><a href=\"https://www.itsnicethat.com/articles/jackson-bowley-xerox-photography-250718\" rel=\"nofollow\">伦敦摄影师 Jackson Bowley 的个人肖像摄影项目 Xerox</a></strong>。</p><p>Jackson Bowley 去年刚从中央圣马丁学院的文化、批评和策展专业本科毕业，但已经与&nbsp;<em>Notion、i-D、Wonderland</em>&nbsp;和&nbsp;<em>Beauty Papers</em> 等多个时尚媒体有过合作。在 Xerox 这个项目中，他把人物肖像扫描到旧报纸、旧杂志上，在往常光鲜亮丽的美妆造型上制造出一种困惑、朦胧的质感。</p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132820uyK1rgqxctOnsw7z.jpg\" data-ratio=\"1.425414\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132835DvZNhK4iyJPgS5HA.jpg\" data-ratio=\"1.425414\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132844z0Hbs2ZR1pJnBIiO.jpg\" data-ratio=\"1.432320\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132856lt7xvM0zr4giDAJn.jpg\" data-ratio=\"1.363260\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132904wk58IoHcjZsGeFTL.jpg\" data-ratio=\"1.339779\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132914m3ENVXqisjrwBobH.jpg\" data-ratio=\"1.545580\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132926mMAlcjEIFY8Ns7a3.jpg\" data-ratio=\"1.430939\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132934ZeBfzHl3nSURwOQ4.jpg\" data-ratio=\"1.450276\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807301329427hJnpfKjcuml0HF5.jpg\" data-ratio=\"1.411602\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730132950pa9dgXSNFxlorMDB.jpg\" data-ratio=\"1.422652\" data-format=\"jpeg\"> </figure></div><p><b><a href=\"http://nowre.com/fashion/344185/freitag-weichengshilvxingzheliangshendazao-f511-skipper-duoyongtubeibao/\" rel=\"nofollow\">Freitag 开售 F511 SKIPPER 多用途背包</a>。</b></p><p>F511 SKIPPER 可装下笔记本电脑、日常杂物，可双肩背、直向手提或横向手提，容量为 19 升，大小为 26 x 13 x 27 厘米，售价 2310 元。<br></p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730135108SVrdQmYp1ei9EwGJ.jpg\" data-ratio=\"0.600000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807301351198wHVkhfbnCWrUQR3.jpg\" data-ratio=\"0.600000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730135129i78sMY20jGSrnXDm.jpg\" data-ratio=\"0.600000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730135138j8Xdfr3qxTl2UeBz.jpg\" data-ratio=\"0.600000\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/201807301351497sckVwTBIR0b2Zh4.jpg\" data-ratio=\"0.600000\" data-format=\"jpeg\"> </figure></div><p><strong><a href=\"https://wwd.com/fashion-news/street-style/moscow-welcomes-new-skateboard-shop-gosha-paccbet-1202766422/\" rel=\"nofollow\">Gosha Rubchinskiy 孵化的第一个街头品牌 Rassvet 发布 Lookbook，并宣布旗下多品牌集合店&nbsp;Oktyabr 在莫斯科开业</a></strong>。<br></p><p>Rassvet 和 Okyabr 的创始人是 24 岁的 Tolia Titaev。集合店的名字取自莫斯科地铁站 Oktyabrskaya，滑板爱好者经常在这里的列宁雕像下见面切磋技艺。Tolia Titaev 说希望集合店也能成为这座城市的滑板社群交流会面的中心。<br></p><div class=\"com-insert-images multiple\"><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730141343sC0YxKwgnbj8SGLe.jpg\" data-ratio=\"1.303075\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730141355oVCByN9cGFMlOk6g.jpg\" data-ratio=\"1.303075\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730141406vwUWOM1Qy4JRoXGj.jpg\" data-ratio=\"1.303075\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730141413mWygjShVq1KDGN5B.jpg\" data-ratio=\"1.303075\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20180730141424NxHMsuUkXAIQia2V.jpg\" data-ratio=\"1.303075\" data-format=\"jpeg\"> </figure><figure style=\"margin: 0px;\"> <img src=\"img/uploads/20