elect": 0, "author": 1135558}, {"id": 236573, "content": "与在乎的人斗嘴", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 934671}, {"id": 236575, "content": "钱", "image": null, "praise_count": 6, "perfect": 0, "select": 0, "author": 1135563}, {"id": 240159, "content": "你弱你有理，控制好度谢谢", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 886307}, {"id": 236577, "content": "和父母同住，两口子的生活及矛盾处理，不希望父母过多插足", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1014209}, {"id": 236578, "content": "抖机灵。真不是任何时候都有趣。", "image": null, "praise_count": 13, "perfect": 0, "select": 0, "author": 789122}, {"id": 236579, "content": "不要让做设计的朋友免费做logo。谢谢了。", "image": null, "praise_count": 80, "perfect": 0, "select": 0, "author": 542691}, {"id": 236580, "content": "和老师吵架时", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1135590}, {"id": 236581, "content": "评价他人", "image": null, "praise_count": 12, "perfect": 0, "select": 0, "author": 740808}, {"id": 236582, "content": "言论。", "image": null, "praise_count": 7, "perfect": 0, "select": 0, "author": 1127930}, {"id": 236583, "content": "交朋友和说话", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1135594}, {"id": 236588, "content": "表白！", "image": null, "praise_count": 23, "perfect": 0, "select": 0, "author": 1117779}, {"id": 237101, "content": "自己的孩子和老人一起带，他们做什么却不问母亲的意见。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 593244}, {"id": 236591, "content": "所谓的直白言论", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1117779}, {"id": 236848, "content": "随便拿别人的弱点开玩笑", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1031072}, {"id": 236594, "content": "开玩笑", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 1085716}, {"id": 236852, "content": "撩妹", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1136131}, {"id": 236853, "content": "亲属与朋友间的装换", "i