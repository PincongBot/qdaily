: 0, "author": 1246746}, {"id": 303896, "content": "习惯就好", "image": null, "praise_count": 4, "perfect": 0, "select": 0, "author": 794661}, {"id": 303641, "content": "博士硕士不如做一个好战士", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 186868}, {"id": 303897, "content": "农村的就要苦大仇深的学习才能有出路", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1470053}, {"id": 303642, "content": "子不养父母", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 1468303}, {"id": 306970, "content": "你爸妈不在家 你不能发脾气", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1479452}, {"id": 303643, "content": "对于饭圈", "image": "img/option/option/201810121434240eHKJ9oWzLSc5uxQ", "praise_count": 0, "perfect": 0, "select": 0, "author": 1160463}, {"id": 303644, "content": "“你有点当哥哥的样子”\n“你有点男子汉的样子”", "image": null, "praise_count": 34, "perfect": 0, "select": 0, "author": 1452411}, {"id": 303900, "content": "我都是为了你好", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1308364}, {"id": 303645, "content": "你又不上学了，还和学生一样的整天看一堆书干嘛！", "image": null, "praise_count": 12, "perfect": 0, "select": 0, "author": 1467857}, {"id": 303646, "content": "不论其他，上来一句就开始鉴定身份", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1332440}, {"id": 303902, "content": "你们女孩子无所谓的，嫁个有钱人不就好了……", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1470099}, {"id": 305694, "content": "“用我三年牢狱，换你一生阴影”", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1477421}, {"id": 303647, "content": "文凭大过本事", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 1464800}, {"id": 304416, "content": "女人就应该如何如何，男人就应该如何如何。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1422752}, {"id": 303649, "content": "你怎么这么物质?", "image": null, "praise_count": 8, "perfect": 0, "select": 0, "author": 1151284}, {"id": 304673, "content": "饭韩国爱豆就是不爱国", "image": null, "praise_count"