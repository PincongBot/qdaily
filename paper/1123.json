author": 735713}, {"id": 111124, "content": "没去过，我是来学习姿势的", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 712761}, {"id": 111381, "content": "可以让我微醺又能好好聊天的", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 687677}, {"id": 111126, "content": "只卖果汁的酒吧", "image": null, "praise_count": 17, "perfect": 0, "select": 0, "author": 698239}, {"id": 111127, "content": "还是更愿意自己一个人在家喝点小酒，周围人一多就不想喝了", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 630553}, {"id": 111383, "content": "有人唱歌的\n", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 690703}, {"id": 111128, "content": "希望没有骚扰，有的是知己", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 734246}, {"id": 111129, "content": "安静的，可以倾诉心声的", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 639434}, {"id": 111130, "content": "民谣音乐的", "image": null, "praise_count": 15, "perfect": 0, "select": 0, "author": 682601}, {"id": 111131, "content": "又吵又闹的，还有人打架的酒吧", "image": null, "praise_count": 19, "perfect": 0, "select": 0, "author": 492549}, {"id": 111132, "content": "没有震耳欲聋的唱得并不好的乐队", "image": null, "praise_count": 4, "perfect": 0, "select": 0, "author": 725905}, {"id": 111133, "content": "Jazz", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 708942}, {"id": 111389, "content": "淡色系的装修，安静", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 735880}, {"id": 111134, "content": "安静舒适，有格调的酒吧", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 608342}, {"id": 111135, "content": "黑手党不可入内", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 622929}, {"id": 111136, "content": "能安静睡上一觉的地方", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 337812}, {"id": 111137, "content": "无烟无烟无烟", "image": null, "praise_count": 67, "perfect": 0, "select": 0, "author": 725775}, {"id": 111138, "content": "安静的。自由的。来点歌。没有聒噪的青年。没有过于殷勤的服务员", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 731003}, {"id": 111394, "content": "相比于酒吧，更喜欢在家里的阳台上看着星星喝", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 735925}, {"id": 111139, "content": "不那么混乱的", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 733065}, {"id": 111395, "content": "只喝酒，不装逼", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 735925}, {"id": 113443, "content": "有特色，优雅，安静的", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 746682}]}