0}, {"id": 29736, "content": "知乎是什么", "image": null, "praise_count": 6, "perfect": 0, "select": 0, "author": 330389}, {"id": 34088, "content": "在现实生活中已无处装逼的人", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 350264}, {"id": 28969, "content": "装", "image": null, "praise_count": 8, "perfect": 0, "select": 0, "author": 177807}, {"id": 31018, "content": "强行装B", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 39499}, {"id": 28971, "content": "喜欢抖激灵和喜欢看别人抖激灵的人。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 274147}, {"id": 32043, "content": "求知欲强的人", "image": "img/option/option/20160702182553BPkSAzMwh5ZvlXqW.jpg", "praise_count": 4, "perfect": 0, "select": 0, "author": 306521}, {"id": 32811, "content": "我上知乎@……", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 346595}, {"id": 28973, "content": "看干货的地方", "image": null, "praise_count": 13, "perfect": 0, "select": 0, "author": 280038}, {"id": 29230, "content": "想找到自我存在的人，寻求现代生活的一种最佳生活方式！", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 329951}, {"id": 29998, "content": "闷骚的人", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 270604}, {"id": 35886, "content": "免费套小黄文", "image": null, "praise_count": 4, "perfect": 0, "select": 0, "author": 375399}, {"id": 28975, "content": "本来是为了开阔眼界，结果让自己越来越狭隘，我就这样", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 325895}, {"id": 29232, "content": "了解更多同龄人眼中自己不知道的世界，", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 329964}, {"id": 31281, "content": "想看“如何评价XXX”的人", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 297479}, {"id": 30002, "content": "乐于分享，希望出名的人；或者装bility的人；或者只想看答案的人~比如我", "image": null, "praise_count": 8, "perfect": 0, "select": 0, "author": 295995}, {"id": 29491, "content": "自我感觉逼格很高的人 也可能是天涯豆瓣转战革命军", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 315426}, {"id": 28980, "content": "不知道啊", "image": null, "praise_count": 7, "perfect": 0, "select": 0, "author": 315168}, {"id": 29752, "content": "上班时间不能浏览太花哨的网页，装模作样，一本正经的码字。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 332015}, {"id": 30522, "content": "一小撮在欧美日韩逗留的破落户与另一大撮因种种原因未能实现出国梦的破落户。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 200176}, {"id": 29758, "content": "学知识，又不想看大篇幅文章的人", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 272595}]}