": 0, "author": 315838}, {"id": 50471, "content": "呵呵的那种", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 433201}, {"id": 60199, "content": "丑人多作怪", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 526423}, {"id": 50472, "content": "只要是卖萌。", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 473884}, {"id": 50474, "content": "多老多丑多胖也卖萌的人。", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 473908}, {"id": 53290, "content": "本宝宝，宝宝你麻痹", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 311407}, {"id": 50475, "content": "宝宝  宝宝  宝宝", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 471152}, {"id": 54059, "content": "卖个萌都假的要死", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 492698}, {"id": 50732, "content": "讨厌各种买萌", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 416676}, {"id": 51252, "content": "丑的", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 478971}, {"id": 50754, "content": "诸如此类的话:\n不要这样啦~\n人家~\n好的呀好的呀~\n么么哒~", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 448247}, {"id": 51013, "content": "我想大概就是今年冯巩在春晚的小品吧……", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 325838}, {"id": 52300, "content": "无法忍受自己卖萌", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 436707}, {"id": 62796, "content": "ladybear", "image": "img/option/option/20160606145029oMEQveDin1ct95GZ.jpg", "praise_count": 0, "perfect": 0, "select": 0, "author": 540384}, {"id": 51539, "content": "一卖萌就皮笑肉不笑还是大方脸的人", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 477081}, {"id": 51028, "content": "刻意的嗲聲嗲氣", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 61509}, {"id": 51796, "content": "强行卖萌和强行装逼一样致命?", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 478948}, {"id": 50523