: 0, "select": 0, "author": 1495532}, {"id": 343349, "content": "喜欢看无意义短视频的人", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1643907}, {"id": 343605, "content": "同意以上几乎全部，难得看到底的测试话题。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1324544}, {"id": 343350, "content": "别人说的大道理", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1426067}, {"id": 343351, "content": "大家都在玩，但自己觉得无聊的游戏（诸如黑魂，克苏鲁的呼唤，人类一败涂地）\n健身房的私教\n知乎上面大篇幅，但没有表格和数据的文字\n毫无建设性意见的言论（很不礼貌 但是想要直接打断）", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1306932}]}