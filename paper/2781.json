age": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1517920}, {"id": 327695, "content": "跟出租车司机聊天", "image": null, "praise_count": 121, "perfect": 0, "select": 0, "author": 852421}, {"id": 327951, "content": "看桥和路还有房子", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1379349}, {"id": 327696, "content": "去菜市场逛逛，", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 1574779}, {"id": 327952, "content": "在人流密集的大馬路上盯人看群像", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 1585936}, {"id": 326928, "content": "定位周边看有多少外卖餐厅", "image": null, "praise_count": 16, "perfect": 0, "select": 0, "author": 688713}, {"id": 327697, "content": "微博或者豆瓣上看城市有没有近期活动", "image": null, "praise_count": 10, "perfect": 0, "select": 0, "author": 712279}, {"id": 327953, "content": "了解一个城市的公共交通，并通体验一把", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1243568}, {"id": 327698, "content": "看城中村", "image": null, "praise_count": 38, "perfect": 0, "select": 0, "author": 1507574}, {"id": 327954, "content": "站在最高的地方看", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1585947}, {"id": 328722, "content": "看地铁美团和滴滴", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1590354}, {"id": 326930, "content": "观察附近有没有花市和菜市场", "image": null, "praise_count": 70, "perfect": 0, "select": 0, "author": 688713}, {"id": 327699, "content": "看看共享单车有多少、摆得怎么样、能不能刷", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1509913}, {"id": 327955, "content": "大众点评", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1212252}, {"id": 326931, "content": "对比超市和小卖部的物价差别有多大", "image": null, "praise_count": 30, "perfect": 0, "select": 0, "author": 688713}, {"id": 327700, "content": "一条街有几家好吃的", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 263797}, {"id": 327956, "content": "吃当地小吃，和当地人聊天", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1499658}, {"id": 329748, "content": "看地图", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1595636}, {"id": 326932, "content": "算算隔多远能遇着一个便利店", "image": null, "praise_count": 262, "perfect": 0, "select": 0, "author": 688713}, {"id": 327701, "content": "公厕", "image": null, "praise_count": 71, "perfect": 0, "select": 0, "author": 1215971}, {"id": 326933, "content": "看晚上还有没有能买吃的的地方", "image": null, "praise_count": 216, "perfect": 0, "select": 0, "author": 688713}, {"id": 327702, "content": "公交车……", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 547031}, {"id": 327958, "content": "去苍蝇馆！（就是俗称的路边摊）", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1127630}, {"id": 327703, "content": "开到一个陌生的城市，我会坐上最近的公交从头到尾作几遍，看着窗外，这是我了解一个城市的方法！", "image": "img/option/option/201902151222516VTrFfz3Q8qAnUiu.jpg", "praise_count": 47, "perfect": 0, "select": 0, "author": 1481692}, {"id": 327704, "content": "多远有一个公厕", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1584558}, {"id": 327960, "content": "去便利店看看贩卖的商品，去市中心的商场逛逛", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1586004}, {"id": 327705, "content": "询问出租车司机，难道他们不是最了解的吗", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1583756}, {"id": 327706, "content": "地图", "image": null, "praise_count": 11, "perfect": 0, "select": 0, "author": 103310}, {"id": 327962, "content": "看高德", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1586064}, {"id": 333850, "content": "站在街角，观察往来的行人", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1612968}, {"id": 327707, "content": "观察交通的便利性", "image": null, "praise_count": 4, "perfect": 0, "select": 0, "author": 1583809}, {"id": 327963, "content": "看看超市里都买什么。", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 1586067}, {"id": 327708, "content": "每天路过观察菜市场的买买卖卖", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 441779}, {"id": 327709, "content": "登上这座城市最高处！", "image": null, "praise_count": 22, "perfect": 0, "select": 0, "author": 1227146}, {"id": 327965, "content": "天台", "image": "img/option/option/20190217002812sCn8cJHkG53oLd2r", "praise_count": 0, "perfect": 0, "select": 0, "author": 1586092}, {"id": 327968, "content": "忘了从哪本书上看来的了，说菜市场，是一个社会的缩影。", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1586145}, {"id": 327713, "content": "高德，饿了么（美团），微信", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 1584575}]}