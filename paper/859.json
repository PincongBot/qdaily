nt": 5, "perfect": 0, "select": 0, "author": 508464}, {"id": 60444, "content": "男主被打的快挂了，然后突然想起来师傅啊，亲人啊，女主啊什么的，满血复活，打死大boss", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 527525}, {"id": 60189, "content": "刀下留人", "image": null, "praise_count": 23, "perfect": 0, "select": 0, "author": 274247}, {"id": 60190, "content": "猪脚怎么被打都不死", "image": null, "praise_count": 6, "perfect": 0, "select": 0, "author": 463649}, {"id": 60191, "content": "反派死于话多系列", "image": null, "praise_count": 60, "perfect": 0, "select": 0, "author": 482606}, {"id": 60195, "content": "反派话好多 非得等到别人来营救主角才动手", "image": null, "praise_count": 11, "perfect": 0, "select": 0, "author": 519587}, {"id": 61476, "content": "总是在拖后腿的女主", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 533848}, {"id": 60198, "content": "很乱，看书详细多了", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 526203}, {"id": 60200, "content": "女扮男装，大家都发现不了，称兄道弟，后来一剑挑开头巾。。。。。。转圈转圈的镜头，，，，画面感有米有？", "image": "img/option/option/20160606161505UHoD0YeJtOxNEn9K.jpg", "praise_count": 24, "perfect": 0, "select": 0, "author": 140661}, {"id": 60201, "content": "被虐→潜心修炼→反虐", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 333612}, {"id": 60203, "content": "小说里云里来 雾里去 意境满分 到了电影也好电视剧也好……呵呵", "image": null, "praise_count": 4, "perfect": 0, "select": 0, "author": 493335}, {"id": 64811, "content": "侠客一定到最后能战胜恶人。侠客一定会喜欢喝酒。侠客一定会有意无意把到妹", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 123404}, {"id": 60204, "content": "打不死", "image": null, "praise_count": 12, "perfect": 0, "select": 0, "author": 526482}, {"id": 60205, "content": "怎么苗家剑法和独孤九剑的招式一样", "image": null, "praise_count": 8, "perfect": 0, "select": 0, "author": 374869}, {"id": 60206, "content": "解药好难求", "image": null, "praise_count": 18, "perfect": 0, "select": 0, "author": 526482}, {"id": 60207, "content": "英雄救美桥段", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 526502