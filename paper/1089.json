raise_count": 0, "perfect": 0, "select": 0, "author": 672695}, {"id": 95772, "content": "一定要走在正中央的人行道上。", "image": null, "praise_count": 5, "perfect": 0, "select": 0, "author": 644875}, {"id": 96540, "content": "duochi蔬菜水果增加自身免疫力，补充维生素", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 672695}, {"id": 95773, "content": "过马路时会不停的看四周来的车", "image": null, "praise_count": 11, "perfect": 0, "select": 0, "author": 667921}, {"id": 97821, "content": "少和丑人说话", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 663476}]}