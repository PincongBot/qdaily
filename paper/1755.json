t": 0, "select": 0, "author": 1061902}, {"id": 216327, "content": "说反话", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1056538}, {"id": 215560, "content": "提出观点，然后公开怼~(但是绝不牵扯黑历史，就事论事)", "image": null, "praise_count": 4, "perfect": 0, "select": 0, "author": 315594}, {"id": 215561, "content": "发朋友圈，哈哈", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1061920}, {"id": 215817, "content": "开玩笑的说出真正想说的", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1062665}, {"id": 219145, "content": "不表达", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1026373}, {"id": 215562, "content": "顾左右而言他...就是不表达真实情感", "image": null, "praise_count": 15, "perfect": 0, "select": 0, "author": 1000046}, {"id": 215563, "content": "发朋友圈仅自己可见✿◡‿◡", "image": null, "praise_count": 38, "perfect": 0, "select": 0, "author": 1061923}, {"id": 215819, "content": "真心话写在个人简介", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1157650}, {"id": 215564, "content": "写下来", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 718143}, {"id": 215565, "content": "攒在心里的夸奖等到特别自然的时机再说出来", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 396994}, {"id": 215821, "content": "碎碎念 ", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1060581}, {"id": 215566, "content": "自黑", "image": null, "praise_count": 12, "perfect": 0, "select": 0, "author": 796418}, {"id": 215822, "content": "碎碎念", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1060581}, {"id": 215567, "content": "写纸条", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1052537}, {"id": 215568, "content": "装作开玩笑的样子", "image": null, "praise_count": 28, "perfect": 0, "select": 0, "author": 966975}, {"id": 216082, "content": "带入语境", "image": "img/option/option/20170626163013ruZgv6SJq1hzxno8", "praise_count": 0, "perfect": 0, "select": 0, "author": 958755}, {"