": 0, "author": 1174217}, {"id": 246539, "content": "完美主义", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1176323}, {"id": 245772, "content": "以偏见、固执和傲慢，回执自己的偏见、固执和傲慢。", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 726836}, {"id": 246028, "content": "没有对象", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 1174226}, {"id": 245773, "content": "急躁不淡定", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 746493}, {"id": 246029, "content": "穷", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 998695}, {"id": 246541, "content": "憎恶分明", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1176323}, {"id": 249357, "content": "太能忍了吧 有时觉得自己何必要忍着啊 但改不了啊", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1179559}, {"id": 245774, "content": "穷", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1052077}, {"id": 246030, "content": "讨好别人委屈自己", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 1174227}, {"id": 245775, "content": "原谅自己不是最优秀的人", "image": null, "praise_count": 22, "perfect": 0, "select": 0, "author": 1161523}, {"id": 246031, "content": "大概也只有心软了", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1174230}, {"id": 245776, "content": "不适合女装", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 1173743}, {"id": 246032, "content": "不能做自己喜欢的事情，不够努力…不敢有发梦想", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1173885}, {"id": 245777, "content": "特别不随和，主观意识很强烈", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 1173751}, {"id": 246033, "content": "没有我想象中的聪明", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 1174239}, {"id": 245778, "content": "丑到习惯成自然吧", "image": null, "praise_count": 9, "perfect": 0, "select": 0, "author": 1120397}, {"id": 246034, "content": "近视", "image": null, "p