erfect": 0, "select": 0, "author": 911087}, {"id": 175627, "content": "魅丽文化", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 902265}, {"id": 174860, "content": "曲一线教育", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 958752}, {"id": 175116, "content": "网络作家.", "image": null, "praise_count": 0, "perfect": 0, "select": 0, "author": 959650}, {"id": 173581, "content": "封面写着销量突破多少多少，什么纪念版，黄金版，铂金版|･ω･｀)，男人沉默女人流泪╮（╯＿╰）╭", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 312511}, {"id": 177165, "content": "出版类的文学作品，豆瓣推荐，成功学", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 281205}, {"id": 173582, "content": "一、教你怎么说话、怎么做人以及告诉你什么是人性的弱点之类的书\n二、霸道总裁、都市爱情、校园言情、玄幻穿越、另类武侠。\n三、烂大街的心灵鸡汤看着都想吐", "image": null, "praise_count": 10, "perfect": 0, "select": 0, "author": 746714}, {"id": 173838, "content": "封面是作者本人的，只看过袁腾飞老师写的历史书，当故事读，基础。    其他时候特别看重封面设计。", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 955519}, {"id": 189966, "content": "畅销书", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 843297}, {"id": 173583, "content": "什么什么微博大V的生活哲学", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 239189}, {"id": 173839, "content": "毒鸡汤、励志、成功学、育才、五三（这个才是重点！）", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 837870}, {"id": 173584, "content": "封腰乱吹。", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 955026}, {"id": 174608, "content": "鸡汤", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 956377}, {"id": 173841, "content": "成功", "image": null, "praise_count": 3, "perfect": 0, "select": 0, "author": 782981}, {"id": 174353, "content": "鸡汤 青春文学", "image": null, "praise_count": 1, "perfect": 0, "select": 0, "author": 955028}, {"id": 174609, "content": "因为一部电视剧就火的一塌糊涂", "image": null, "praise_count": 2, "perfect": 0, "select": 0, "author": 698804}, {"id": 174865, "content": "江南",